   <text>
      <body>
         <div type="writingSession" n="1"><p rend="right"><pb facs="3236_Schnitzler_Lebendige-Stunden_001"/>Meinem lieben Hugo</p><closer><signed>ArthSch</signed></closer><postscript><dateline><rs type="place" ref="#pmb50">Wien</rs><space unit="chars" quantity="1"/><date><anchor type="commentary" xml:id="K_L01196-1"/>Jänner 902<note type="commentary" corresp="K_L01196-1">Am <date when="1901-12-23">23. 12. 1901</date> wurde <rs type="work" ref="#pmb29863">Lebendige
                           Stunden</rs> vom <rs type="work" ref="#pmb47979">Börsenblatt für den
                           deutschen Buchhandel</rs> als Neuerscheinung gemeldet. Am 
                        <ref type="schnitzler-briefe" target="L03322" subtype="date-only"/>
                        bestätigte <rs type="person" ref="#pmb2167">Salten</rs> den Erhalt des
                        Buches, sodass der Versand der Widmungsexemplare am 
                        Vortag erfolgt sein dürfte.</note></date></dateline></postscript></div>
         <div type="writingSession" n="2"><space dim="vertical" unit="line" quantity="1"/><p rend="center"><pb facs="3236_Schnitzler_Lebendige-Stunden_002"/><hi rend="pre-print">Arthur Schnitzler</hi></p><p rend="center"><hi rend="pre-print"><rs type="work" ref="#pmb29863">Lebendige Stunden</rs></hi></p><p rend="center"><hi rend="pre-print">Vier Einakter</hi></p><p rend="center"><hi rend="pre-print">Zweite Auflage</hi></p><space dim="vertical" unit="line" quantity="1"/><p rend="center"><hi rend="pre-print"><rs ref="#pmb168" type="place"><hi rend="spaced-out">Berlin</hi></rs><space unit="chars" quantity="1"/><date>1902</date></hi></p><p rend="center"><hi rend="pre-print"><rs ref="#pmb29639" type="org"><hi rend="spaced-out">S. Fi<c rendition="#langesS">s</c>cher, Verlag</hi></rs></hi></p></div>
      </body>
