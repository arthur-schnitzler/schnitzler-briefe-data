      <body>
         <div type="address"><address><addrLine><pb facs="1912_AS_RBH_1_00019"/>Herrn <hi rend="latintype">Dr. Richard
                     Beer-Hofmann –</hi></addrLine><addrLine>aus <rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb44374">St. Morit<unclear>z</unclear></rs></hi></addrLine><addrLine><hi rend="latintype">im <rs type="place" ref="#pmb1061">Engadin</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb51935">Waldhaus</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1912_AS_RBH_1_00018"/><hi rend="pre-print"><rs type="place" ref="#pmb45260">Insel Brioni i. d. Adria</rs>.</hi></p><p rend="center"><hi rend="pre-print">Straße in <rs type="place" ref="#pmb52314">Val Madonna</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1912_AS_RBH_1_00019"/>Herzliche Grüße Ihnen <rs type="person" ref="#pmb2534 #pmb10860 #pmb13923 #pmb2668" subtype="implied">Allen</rs>. – Es i<c rendition="#langesS">s</c>t
               wunder<c rendition="#langesS">s</c>chön hier, wir bleiben noch bis nach <date>20. 8</date>, fahren da<c rendition="#gemination-n">nn</c> direct <rs type="place" ref="#pmb40516"><hi rend="latintype">Sils Maria</hi></rs>. Schreiben Sie ein Wort, wies Ihnen <rs type="person" ref="#pmb2534 #pmb10860 #pmb13923 #pmb2668" subtype="implied">allen</rs> geht.</p><closer>Ihr<lb/><signed>Arthur</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Herzl. Grüsse!</p><closer><signed>Olga.</signed></closer></div>
      </body>
