      <body>
         <div type="writingSession" n="1"><p><pb facs="A-124219_0002"/>Meinem lieben Felix Salten</p><closer><signed>Arthur Sch</signed></closer><postscript><dateline><rs type="place" ref="#pmb168">Berlin</rs><space unit="chars" quantity="1"/><anchor type="commentary" xml:id="K_L03607-1"/><date when="1906-02">Feber 906</date><note type="commentary" corresp="K_L03607-1"><rs type="work" ref="#pmb29905">Der Ruf des Lebens</rs> wurde am <date when="1906-02-13">13. 2. 1906</date> vom <rs type="work" ref="#pmb47979">Börsenblatt für den deutschen Buchhandel</rs> als Neuerscheinung gemeldet.
                     Am <ref type="schnitzler-tagebuch" subtype="date-only" target="1906-02-21"/> war <rs type="person" ref="#pmb2121">Schnitzler</rs> in <rs type="place" ref="#pmb168">Berlin</rs> und vermerkte
                     sich im  <rs type="work" ref="#pmb33243">Tagebuch</rs>: »<quote>Bei <rs type="person" ref="#pmb11324">S. Fischer</rs> (Bücher verschickt).</quote>«</note>.</dateline></postscript></div>
         <div type="writingSession" n="2"><space dim="vertical" unit="line" quantity="1"/><p rend="center"><pb facs="A-124219_0003"/><hi rend="pre-print"><hi rend="bold"><rs type="work" ref="#pmb29905"><hi rend="spaced-out">Der Ruf des Lebens</hi></rs></hi></hi></p><p rend="center"><hi rend="pre-print"><hi rend="spaced-out">Schau<c rendition="#langesS">s</c>piel in drei Akten von</hi></hi><lb/><hi rend="pre-print"><hi rend="bold"><hi rend="spaced-out">Arthur Schnitzler</hi></hi></hi></p><space dim="vertical" unit="line" quantity="1"/><p rend="center"><hi rend="pre-print"><rs ref="#pmb29639" type="org"><hi rend="spaced-out">S. Fi<c rendition="#langesS">s</c>cher, Verlag</hi></rs><hi rend="spaced-out">,</hi><space unit="chars" quantity="2"/><rs ref="#pmb168" type="place"><hi rend="spaced-out">Berlin</hi></rs></hi></p><p rend="center"><hi rend="pre-print"><date when="1906"><hi rend="spaced-out">1906</hi></date></hi></p></div>
      </body>
