   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1903_AS_RBH_1_00045"/>Richard Beer Hofma<c rendition="#gemination-n">nn</c></addrLine><addrLine><rs ref="#pmb40101" type="place">Lie<c rendition="#langesS">s</c>inger Stra<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e 2</rs></addrLine><addrLine><hi rend="stamp"><rs type="place" ref="#pmb173">Rodaun</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1903_AS_RBH_1_00045"/>Ich bitte Sie all<c rendition="#langesS">s</c>o <date>Mittwoch</date><space unit="chars" quantity="1"/><time>halb eins</time><space unit="chars" quantity="1"/><anchor type="commentary" xml:id="K_L01312-1"/><rs type="place" ref="#pmb44464">Schopenhauerga<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e 37</rs><note type="commentary" corresp="K_L01312-1"><rs type="place" ref="#pmb44464">Schopenhauerstraße 39</rs> war die Adresse der
                     <rs type="org" ref="#pmb44466" subtype="implied">Synagoge</rs>, in der am <ref target="1903-08-26" type="schnitzler-tagebuch" subtype="date-only"/> die
                  Trauung von <rs type="person" ref="#pmb2121">Schnitzler</rs> und <rs type="person" ref="#pmb2173">Olga Gussmann</rs> stattfand.</note> als Beistand zu fungiren
               und die Sache durchaus als vertraulich zu behandeln</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr <signed>Arthur</signed></closer></div>
      </body>
