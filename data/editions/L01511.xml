         <div type="writingSession" n="1"><p><pb facs="Widmungsexemplare_Seite_082"/>Herrn Arthur Schnitzler</p><closer>in herzlicher Verehrung<lb/><signed>D<hi rend="superscript">r</hi> Burckhard</signed></closer></div>
