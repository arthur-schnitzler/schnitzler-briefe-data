      <body>
         <div type="address"><address><addrLine><pb facs="1921_AS_RBH_00004"/>Hrn <hi rend="latintype">Richard Beer Hofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb235251">Hasenauerstr 59</rs></hi>.</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1921_AS_RBH_00003"/><hi rend="pre-print"><rs type="place" ref="#pmb45258"><hi rend="bold">München</hi></rs><space unit="chars" quantity="3"/>Partie an der <rs type="place" ref="#pmb52586">Isar</rs> – Blick gegen Süden</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1921_AS_RBH_00004"/>Herzliche Grüße</p><closer>Ihr<lb/><signed>Arthur</signed></closer><postscript><dateline rend="right"><anchor type="textConst" xml:id="T_L02366-1"/><date>8. 5. 1921</date><note type="textConst" corresp="T_L02366-1">ab hier seitlich zum Text</note></dateline><p><anchor type="commentary" xml:id="K_L02366-1"/>Ge<c rendition="#langesS">s</c>tern<note type="commentary" corresp="K_L02366-1"><ref target="1921-05-07" type="schnitzler-tagebuch" subtype="See"/>.
                  </note>, in <rs type="place" ref="#pmb52583">Harlaching</rs>, hab ich viel Ihrer,
                  und schöner Tage gedacht.</p></postscript></div>
      </body>
