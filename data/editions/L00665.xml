   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1897_AS_RBH_1_00021"/>Herrn <hi rend="latintype">Dr. Rich.
                     Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb50" type="place"><hi rend="latintype">Wien</hi></rs></addrLine><addrLine><rs ref="#pmb190427" type="place"><hi rend="latintype">I. Wollzeile 15</hi></rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1897_AS_RBH_1_00022"/><salute>Lieber Richard;</salute> ge<c rendition="#langesS">s</c>tern hier im <rs ref="#pmb35546" type="org">Dt<c rendition="#langesS">s</c>ch. Th.</rs><space unit="chars" quantity="1"/><rs ref="#pmb29899" type="work">Freiwild</rs>; der heutigen »<rs ref="#pmb29917" type="work">Liebelei</rs>« entgleite ich. Fahre nach <rs ref="#pmb484" type="place">Zürich</rs>. Bin <date>Montag</date> in <rs ref="#pmb182" type="place">Paris</rs>. – Schreiben Sie mir zu <rs ref="#pmb11485" type="person">Goldmann</rs>. – Grüßen Sie.</p><p>Herzlich Ihr<lb/><signed>Arthur.</signed></p></div>
      </body>
