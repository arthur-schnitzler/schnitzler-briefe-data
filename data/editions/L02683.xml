         <div type="writingSession" n="1"><opener><seg rend="center"><pb facs="HS.NZ85.1.3169_0049"/><rs type="place" ref="#pmb50">wien</rs> fr <rs type="place" ref="#pmb88960">pontafel</rs> 55 12 <date>13/10</date><space unit="chars" quantity="1"/><time>10/15</time> =</seg></opener><p><anchor type="commentary" xml:id="K_L02683-1"/>ankomme<note type="commentary" corresp="K_L02683-1"><rs type="person" ref="#pmb11485">Goldmann</rs> wurde von <rs type="person" ref="#pmb2121">Schnitzler</rs> und <rs type="person" ref="#pmb12740">Gustav
                     Schwarzkopf</rs> in <rs type="place" ref="#pmb50">Wien</rs> empfangen. Er blieb
                  bis zum <ref type="schnitzler-tagebuch" target="1899-10-21" subtype="date-only"/>.</note><space unit="chars" quantity="1"/><date when="1899-10-13">heute</date><space unit="chars" quantity="1"/><time>abend</time><space unit="chars" quantity="1"/><time>9 uhr 45</time> = <signed>goldmann =</signed></p></div>
