         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00053-V"/><rs type="place" ref="#pmb468">Europa</rs></addrLine><addrLine><rs type="place" ref="#pmb41240">Austria</rs></addrLine><addrLine>Herrn</addrLine><addrLine>D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168815">18. Sternwartestrasse 71</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00053-R"/><hi rend="capitals"><hi rend="pre-print"><rs type="org" ref="#pmb53340">Norddeutscher Lloyd</rs>, <rs type="place" ref="#pmb891">Bremen</rs></hi></hi></p><p rend="center"><rs type="org" ref="#pmb148348"><hi rend="pre-print">D. »Berlin«</hi></rs></p><p rend="center"><hi rend="pre-print"><anchor type="textConst" xml:id="T_L03533-1"/>Gesellschaftshalle<note type="textConst" corresp="T_L03533-1">Druckfehler: »<quote>Gesellscaaftshalle</quote>«</note> 1. Kl.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00053-V"/>vor <rs type="place" ref="#pmb44053">New York</rs><lb/><date when="1930-05-17">17. 5. 30</date></dateline></opener><p><salute>Lieber,</salute> die Fahrt, die nach zehn unruhigen Tagen <date when="1930-05-18">morgen</date><space unit="chars" quantity="1"/><time>früh</time> endigt, war trotz allem sehr schön. Ich denke viel und gut an Sie
               und grüße sie herzlichst</p><closer>Ihr <lb/><signed>Felix Salten</signed></closer></div>
      </body>
