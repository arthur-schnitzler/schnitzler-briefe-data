      <body>
         <div type="address"><address><addrLine><pb facs="1896_AS_RBH_2_00009"/><hi rend="latintype">Dr Rich Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><rs ref="#pmb190427" type="place"><hi rend="latintype">I Wollzeile 15</hi></rs></addrLine><addrLine>4. Stock.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1896_AS_RBH_2_00010"/><salute>Lieber Richard,</salute> morgen <date>So<c rendition="#gemination-n">nn</c>tag</date> Abend <hi n="1" rend="underline">nicht</hi> bei Ihnen,<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ondern <rs type="place" ref="#pmb43"><hi rend="latintype">Imperial</hi></rs>. – Näheres <hi rend="underline" n="1">heut</hi> Abe<unclear>nd</unclear><space unit="chars" quantity="1"/><hi n="1" rend="underline">nach</hi> den <rs ref="#pmb31737" type="work">Müttern</rs>. Wir (<rs ref="#pmb11740" type="person">Hugo</rs><space unit="chars" quantity="1"/><hi rend="latintype">etc</hi>) im <rs type="place" ref="#pmb44">Riedhof</rs>. Ich
                  ko<c rendition="#gemination-m">mm</c>e mit <rs ref="#pmb10986" type="person">Brahm</rs><space unit="chars" quantity="1"/><rs type="person" ref="#pmb11701">Hir<c rendition="#langesS">s</c>chf</rs> nach<supplied>.</supplied><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehe Sie übrigens <rs ref="#pmb31737" type="work" subtype="implied">Zwischenakt</rs></p><closer>Herzlich Ihr <signed>A.</signed></closer></div>
      </body>
