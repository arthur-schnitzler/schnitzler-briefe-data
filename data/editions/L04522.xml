   <text>
      <body>
         <div type="image"><p rend="center"><pb facs="HS00048772X_0357"/><hi rend="pre-print"><rs type="place" ref="#pmb189">Semmering</rs>. <rs type="place" ref="#pmb353555">Villa Leibenfrost</rs> – Dependancen des <rs type="place" ref="#pmb413">Südbahnhotel</rs> und <rs type="place" ref="#pmb442">Kurhaus</rs></hi></p></div>
         <div type="address"><address><addrLine><pb facs="HS00048772X_0358"/><hi rend="latintype">Herrn</hi></addrLine><addrLine><hi rend="latintype">Gustav Schwarzkopf</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb207296"><hi rend="latintype">I. Tiefer Graben 23</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="HS00048772X_0358"/><salute>Lieber Gu<c rendition="#langesS">s</c>tav,</salute> <c rendition="#langesS">s</c>o <c rendition="#langesS">s</c>ind wir denn hier
      gelandet, nach kurzem <anchor type="commentary" xml:id="K_L04522-1"/><hi rend="latintype"><rs type="place" ref="#pmb33">St. Gilgner</rs></hi>
               Aufenthalt<note type="commentary" corresp="K_L04522-1">Die Tage vom <ref type="wienerschnitzler" target="1911-07-24" subtype="date-only"/> bis zum <ref type="wienerschnitzler" target="1911-07-29" subtype="date-only"/> verbrachten <rs type="person" ref="#pmb2173">Olga</rs> und <rs type="person" ref="#pmb2121">Arthur Schnitzler</rs> in <rs type="place" ref="#pmb33">St. Gilgen</rs>.</note>, – haupt<c rendition="#langesS">s</c>ächlich um mit
      <rs type="person" ref="#pmb12701" subtype="implied">Mama</rs> hier zu<c rendition="#langesS">s</c>a<c rendition="#gemination-m">mm</c>en zu <c rendition="#langesS">s</c>ein, die aber
      gleich wieder nach <rs type="place" ref="#pmb662">Baden</rs>
      gefahren i<c rendition="#langesS">s</c>t. Abge<c rendition="#langesS">s</c>ehn von den
      Schrecken der Saison i<c rendition="#langesS">s</c>t es
      hier <c rendition="#langesS">s</c>chön wie i<c rendition="#gemination-m">mm</c>er u
               <pb facs="HS00048772X_0357"/>wir gedenken (mit den <rs type="person" ref="#pmb12692 #pmb2238">Kindern</rs>) auch eine Woche
      zu bleiben.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr <signed>A.</signed></closer><postscript><dateline><hi rend="latintype"><rs type="place" ref="#pmb413">Südbahnhotel</rs></hi><space unit="chars" quantity="5"/><date>8. 8. 911</date></dateline></postscript></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/><signed>Olga.</signed></p></div>
      </body>
