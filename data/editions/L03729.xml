            <bibl xml:id="pmb295177">
               <title>Das erste Kapitel. Schauspiel in drei Akten</title>
               <title type="werk_namensvariante">Das erste Capitel</title>
               <title type="werk_link">https://archive.org/details/daserstekapitels00ples/page/n1</title>
