      <body>
         <div type="writingSession" n="1"><opener><salute><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00029"/>Lieber
                  Freund,</salute></opener><p>ich beglückwün<c rendition="#langesS">s</c>che dich von Herzen zu deinem großen <anchor type="commentary" xml:id="K_L00855-1"/>Erfolg<note type="commentary" corresp="K_L00855-1"><rs type="event" ref="#pmb35315">Premiere
                  von <rs ref="#pmb30127" type="work">Der Star</rs></rs> am <date>12. 11. 1898</date> am
                     <rs ref="#pmb35053" type="org">Lessing-Theater</rs> in <rs ref="#pmb168" type="place">Berlin</rs>.</note> in <rs ref="#pmb168" type="place">Berlin</rs>,
                  <unclear>und</unclear> grüße dich vielmals</p><closer>dein <signed>Arthur Schnitzler</signed></closer><postscript><dateline><rs ref="#pmb50" type="place">Wien</rs><space unit="chars" quantity="1"/><date when="1898-11-13">13. 11. 98.</date></dateline></postscript></div>
      </body>
