   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="HS.NZ85.1.3169_0040"/>arthur schnitzler</addrLine><addrLine><rs type="place" ref="#pmb88963">nuernberg kaiserhof</rs>:=</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="HS.NZ85.1.3169_0039"/>sandte dir <date when="1899-09-17">gestern</date>
               langes <anchor type="commentary" xml:id="K_L02682-1"/>telegramm<note type="commentary" corresp="K_L02682-1">nicht überliefert</note><space unit="chars" quantity="1"/><rs type="place" ref="#pmb44172">nuernberg</rs> poste restante worin ich dir
               mittheilte dass ich <date when="1899-09-23">samstag</date> meinen urlaub antrete nach
                  <rs type="place" ref="#pmb263">florenz</rs> fahre und mich wenn du willst auch
               dort oder unterwegs mit dir <anchor type="commentary" xml:id="K_L02682-2"/>treffen<note type="commentary" corresp="K_L02682-2">Am Folgetag, einem Dienstag
                     (<ref type="schnitzler-tagebuch" target="1899-09-19" subtype="date-only"/>),
                  reiste <rs type="person" ref="#pmb2121">Schnitzler</rs> nach <rs type="place" ref="#pmb146">Frankfurt am Main</rs>, wo er auf <rs type="person" ref="#pmb11485">Goldmann</rs> traf.</note> koennte. natuerlich werde ich mich
               auch unendlich freuen dich in <rs type="place" ref="#pmb146">frankfurt</rs> zu
               sehen.</p><closer>gruss = <signed>goldmann. +</signed></closer></div>
      </body>
