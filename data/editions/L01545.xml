         <listBibl>
            <bibl xml:id="pmb29903" ana="comment">
               <title type="main">Zwischenspiel. Komödie in drei Akten</title>
               <title type="werk_arbeitstitel">Neue Ehe</title>
               <title type="werk_arbeitstitel">Das leichte Leben</title>
               <title type="werk_arbeitstitel">Cäcilie Adams</title>
               <title type="werk_arbeitstitel">Adagio</title>
