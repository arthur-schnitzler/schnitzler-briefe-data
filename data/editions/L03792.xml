      <body>
         <div type="address"><address><addrLine><pb facs="0046_FL81799643"/><hi rend="pre-print">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="pre-print"><rs type="place" ref="#pmb168815">Wien XVIII.
                        Sternwartestrasse 71</rs>.</hi></addrLine></address><address><addrLine><hi rend="latintype">Herrn</hi> Doctor</addrLine><addrLine><hi rend="latintype">Stefan Zweig</hi></addrLine><addrLine><anchor type="commentary" xml:id="K_L03792-1"/><rs type="place" ref="#pmb51">Wien I</rs><note type="commentary" corresp="K_L03792-1">Schreibirrtum. Die Wohnung
                     <rs type="person" ref="#pmb13212">Zweigs</rs> lag im <rs type="place" ref="#pmb58">8. Wiener Gemeindebezirk</rs>.</note></addrLine><addrLine><rs type="place" ref="#pmb249577"><hi rend="latintype">Kochgasse 8</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="0047_FL81799693"/>Herzlichen Dank für die lieben <anchor type="commentary" xml:id="K_L03792-2"/><rs type="place" ref="#pmb27068">Schneeberg</rs>-Grüße<note type="commentary" corresp="K_L03792-2"><ref type="schnitzler-briefe" target="L03632"/>.</note>. Ihr <anchor type="commentary" xml:id="K_L03792-3"/><rs type="work" ref="#pmb296409" subtype="implied">Panama-Feuilleton</rs><note type="commentary" corresp="K_L03792-3"><bibl><rs type="person" ref="#pmb13212">Stefan Zweig</rs>:
                              <rs type="work" ref="#pmb296409">Die Stunde zwischen zwei Ozeanen. Der Panamakanal</rs>. In: <rs type="work" ref="#pmb36374">Neue Freie Presse</rs>,
                              Nr. 16.835, <date>6. 7. 1911</date>, Morgenblatt, S. 1–4</bibl>.</note> hat mich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr bewegt.</p><closer>Guten Sommer.<lb/>Ihr<lb/><signed>ArthSch</signed></closer><postscript><p>Auch von meiner <rs type="person" ref="#pmb2173" subtype="implied">Frau</rs> beste
                  Grüße.</p></postscript></div>
      </body>
