         <div type="writingSession" n="1"><p><pb facs="UBS_Widmungen_00000115"/>Meinem lieben Hermann Bahr<lb/>herzlich<c rendition="#langesS">s</c>t</p><closer><signed>ArthSch</signed></closer></div>
         <div type="writingSession" n="2"><space dim="vertical" unit="line" quantity="1"/><p rend="center"><pb facs=""/><hi rend="pre-print"><rs ref="#pmb29823" type="work">Das Märchen</rs>.</hi></p><p rend="center"><hi rend="pre-print"><hi rend="bold">Schau<c rendition="#langesS">s</c>piel in drei Aufzügen</hi></hi><lb/><hi rend="pre-print">von</hi><lb/><hi rend="pre-print"><hi rend="bold">Arthur Schnitzler.</hi></hi></p><space dim="vertical" unit="line" quantity="1"/><p rend="center"><hi rend="pre-print"><rs ref="#pmb866" type="place"><hi rend="bold">Dresden</hi></rs> und <rs ref="#pmb864" type="place"><hi rend="bold">Leipzig</hi></rs></hi></p><p rend="center"><hi rend="pre-print"><rs ref="#pmb29771" type="org"><hi rend="spaced-out">E. Pier<c rendition="#langesS">s</c>on’s Verlag</hi></rs></hi></p><p rend="center"><hi rend="pre-print"><date><anchor type="commentary" xml:id="K_L00319-1"/>1894<note type="commentary" corresp="K_L00319-1"><rs type="work" ref="#pmb29823">Das Märchen</rs> war am <date when="1894-05-05">5. 5. 1894</date> vom <rs type="work" ref="#pmb47979">Börsenblatt für den deutschen Buchhandel</rs> als Neuerscheinung
                        gemeldet worden. Die Datierung folgt jener der Widmung an <rs type="person" ref="#pmb2167">Felix Salten</rs> vom <ref type="schnitzler-briefe" target="L03600" subtype="date-only"/>.</note></date>.</hi></p></div>
      </body>
