   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00331_CUL_FOTO_CUT_1826"/><handShift scribe="#pmb11391"/>Herrn</addrLine><addrLine>Dr. <hi rend="latintype">Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb168934">IX. Frangasse 1</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00331_CUL_FOTO_CUT_1825"/><handShift scribe="#pmb2537"/>In Gesellschaft Ihrer entzückenden <anchor type="commentary" xml:id="K_L04348-1"/>französischen <rs type="work" subtype="implied" ref="#pmb185653">Annie</rs><note type="commentary" corresp="K_L04348-1"><rs type="person" ref="#pmb27074">Charlotte Wiehe</rs> tourte
                  gerade und hatte <rs type="work" ref="#pmb185653">Souper d’Adieu</rs> (<rs type="work" ref="#pmb30005">Abschiedssouper</rs>) im Repertoire. <rs type="person" ref="#pmb2121">Schnitzler</rs> sah eine Aufführung am <ref type="schnitzler-kultur" subtype="date-only" target="pmb209263"/> im <rs type="place" ref="#pmb77">Raimund-Theater</rs>. </note></p><closer>grüssen schönstens Ihre <signed>Idus Fulda</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb27074"/>Mes meilleurs compliments!</p><closer><signed>Charlotte Wiehe-Berény</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb342708"/>Wann werde ich Sie endlich kennen lernen? Zeit wäre
               es schon!</p><closer><signed>Julie Leipziger.</signed></closer></div>
         <div type="writingSession" n="4"><p><handShift scribe="#pmb10879"/>Ich hoffe Sie <anchor type="commentary" xml:id="K_L04348-2"/>bald in <rs type="place" ref="#pmb50">Wien</rs><note type="commentary" corresp="K_L04348-2"><ref type="schnitzler-tagebuch" subtype="Cf" target="1902-09-28"/>.</note> begrüssen zu können.</p><closer>Henri Bereny</closer></div>
         <div type="writingSession" n="5"><p><handShift scribe="#pmb11485"/>Herzlichen Gruß!</p><closer><signed>Paul Goldmann.</signed></closer></div>
         <div type="writingSession" n="6"><p><handShift scribe="#pmb11391"/>Und auch von mir!</p><closer><signed>Ludwig Fulda</signed></closer></div>
      </body>
