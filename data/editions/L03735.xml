   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="0158_FL81799574"/><anchor type="textConst" xml:id="T_L03735-1"/><hi rend="pre-print">A. S.</hi><note type="textConst" corresp="T_L03735-1">ovaler Absenderkleber</note></addrLine><addrLine><rs ref="#pmb68" type="place"><hi rend="pre-print"><hi rend="capitals">Wien, XVIII.</hi></hi></rs></addrLine><addrLine><rs ref="#pmb168815" type="place"><hi rend="pre-print"><hi rend="capitals">Sternwartestr. 71</hi></hi></rs></addrLine></address><address><addrLine>Hn. Dr Stefan Zweig</addrLine><addrLine><rs type="place" ref="#pmb30">Salzburg</rs>,</addrLine><addrLine><rs type="place" ref="#pmb253003">Kapuzinerberg 5</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="0159_FL81799575"/><rs type="place" ref="#pmb50">Wien</rs><space unit="chars" quantity="1"/><date>5/12 <unclear>29</unclear></date></dateline></opener><p><salute>lieber Stefan Zweig,</salute> ich bestätige endlich nun den Empfang der
               <rs type="work" ref="#pmb295299">kleinen Chronik</rs>, – so klein das Buch ist, noch bin ich am
               <rs type="work" ref="#pmb76935">Columbus</rs> und an der <rs type="work" ref="#pmb76570">Barbara</rs>, und <rs type="work" ref="#pmb295299" subtype="implied">Ihres</rs> ko<c rendition="#gemination-m"/>t erst
               daran, we<c rendition="#gemination-n"/> ich jene beiden zu Ende gelesen (zu dieser Proben Zeit kommt man nicht
               immer dazu) – ich will mich in Muße daran freuen, Dank Gru<c rendition="#langesS">s</c>s und Freund<c rendition="#langesS">s</c>chaft!</p><closer>Herzlichst Ihr <signed>ArthSchnitzler</signed></closer></div>
      </body>
