         <div type="address"><address><addrLine><pb facs="1914_AS_RBH_1_00013"/>Hrn <hi rend="latintype">Dr. Richard</hi></addrLine><addrLine><hi rend="latintype">Beerhofmann</hi></addrLine><addrLine>aus <rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs ref="#pmb34869" type="place"><hi rend="latintype">Kap d’Ail</hi></rs></addrLine><addrLine><rs type="place" ref="#pmb41759"><hi rend="latintype">Riviera</hi></rs></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb166">Frankreich</rs></hi></addrLine></address></div>
