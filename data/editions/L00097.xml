         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="1892_AS_RBH_1_00016"/>Herrn Doctor Richard Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb50" type="place">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb730" type="place">III Seidlgasse 30</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1892_AS_RBH_1_00018"/><salute>Lieber Richard,</salute><space unit="chars" quantity="1"/><date>Din<c rendition="#langesS">s</c>tag</date> vor <time>5 Uhr</time> will uns Hr <rs ref="#pmb12564" type="person"><hi rend="latintype">Rosner</hi></rs> bei mir eine Novelle <anchor type="commentary" xml:id="K_L00097-1"/>vorle<c rendition="#langesS">s</c>en<note type="commentary" corresp="K_L00097-1">Die Lesung dürfte nicht
                  stattgefunden haben.</note>; bitte<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr, ko<c rendition="#gemination-m">mm</c>en
               Sie.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>Arthur</signed></closer><postscript><dateline><date>24. 4. 92</date></dateline></postscript></div>
      </body>
