         <div type="address"><address><addrLine><pb facs="HS.NZ85.1.3175_0007"/>Herrn</addrLine><addrLine>Dr. Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168940">XVIII. Spöttelga<c rendition="#langesS">s</c>se 7</rs>.</addrLine><addrLine><foreign xml:lang="fr"><rs type="place" ref="#pmb687">Autriche</rs>.</foreign></addrLine></address></div>
