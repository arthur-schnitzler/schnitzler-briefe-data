   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1911-1914_OS_RBH_1_00006"/>Frau Paula Beer-Hofmann</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1911-1914_OS_RBH_1_00007"/><salute>Liebe Paula,</salute> Ihr <rs ref="#pmb41709" type="person" subtype="implied" cert="low">Fräulein</rs> hat nur den Mantel
               mitgeschickt, – ich bitte Sie, dem Frl. <rs type="person" ref="#pmb23241">Reiter</rs>
               auch das Unterkleid zu zeigen wegen des Verschlusses, und damit ich weiss, wieviel
               Seide <pb facs="1911-1914_OS_RBH_1_00008"/>ich brauche.</p><p>Vielen Dank!</p><closer><signed>Olga.</signed></closer></div>
      </body>
