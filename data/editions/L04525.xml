      <body>
         <div type="image"><p rend="center"><pb facs="HS00048772X_0363"/><hi rend="pre-print"><rs type="place" ref="#pmb353237">Neuthor</rs></hi><space unit="chars" quantity="5"/><hi rend="pre-print"><rs type="place" ref="#pmb30">Salzburg</rs></hi></p></div>
         <div type="address"><address><addrLine><pb facs="HS00048772X_0364"/>Herrn Gu<c rendition="#langesS">s</c>tav Schwarzkopf</addrLine><addrLine><rs type="place" ref="#pmb51">Wien I</rs></addrLine><addrLine><rs type="place" ref="#pmb207296">Tiefer Graben 23</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="center"><date>14. 1. 903</date></dateline></opener><p>Wir grüßen Sie herzlich, Dr. <rs type="person" ref="#pmb24648">Max</rs> desgleichen,</p><closer><signed>A.</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Grüß Sie Gott!</p><closer><signed>Olga</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb2121"/>So <c rendition="#langesS">s</c>chön und wei<c rendition="#langesS">s</c>s und <c rendition="#langesS">s</c>till!</p></div>
      </body>
