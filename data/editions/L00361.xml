      <body>
         <div type="address"><address><addrLine><pb facs="1894_AS_RBH_2_00015"/>Herrn <hi rend="latintype">Dr. Rich. Beer
                     Hofmann</hi></addrLine><addrLine><rs ref="#pmb213" type="place"><hi rend="latintype">Ischl</hi></rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb766" type="place">Egelmoos 22</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1894_AS_RBH_2_00016"/><salute>Lieber Richard,</salute> ich ko<c rendition="#gemination-m">mm</c> im Lauf des <anchor type="commentary" xml:id="K_L00361-1"/><date>Mittwoch</date><note type="commentary" corresp="K_L00361-1"><ref type="wienerschnitzler" target="1894-08-01" subtype="date-only"/>.</note> in <rs ref="#pmb30" type="place">S.</rs> an u<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>teig auch im <rs ref="#pmb230" type="place">Oe<c rendition="#langesS">s</c>t.
                  Hof</rs> ab. –</p><closer>Herzlichen Gruß<lb/><signed>Arthur</signed></closer></div>
      </body>
