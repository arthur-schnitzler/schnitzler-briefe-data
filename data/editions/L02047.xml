      <body>
         <div type="address"><address><addrLine><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00192"/>Herrn Hermann
                  Bahr</addrLine><addrLine><rs ref="#pmb63" type="place">Wien XIII</rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb165" type="place">St. Veit</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb220" type="place">Veilissengasse</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00193"/><hi rend="pre-print"><rs ref="#pmb113" type="place">Türkenschanz-Park</rs></hi></p></div>
         <div type="writingSession" n="1"><opener><dateline><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00193"/><rs ref="#pmb50" type="place">Wien</rs>, <date>18. 11. 911</date>.</dateline></opener><p><salute>herzlichen Dank, lieber Hermann,</salute> für dein und deiner verehrten <rs type="person" ref="#pmb10818" subtype="implied">Gattin</rs><space unit="chars" quantity="1"/><rs ref="#pmb29943" type="work">Bayreuth</rs> Buch, das ich von einer Rei<c rendition="#langesS">s</c>e
               heimkehrend vorfinde u auf de<c rendition="#langesS">s</c><c rendition="#langesS">s</c>en Lecture ich mich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr freue. Immer Dein
                  <signed>Arthur</signed></p></div>
      </body>
