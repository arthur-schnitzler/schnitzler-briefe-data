   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1901_AS_RBH_1_00009"/>Herrn Dr. <hi rend="latintype">Rich.
                     Beer-Hofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb190427"><hi rend="latintype">I. Wollzeile 15</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1901_AS_RBH_1_00010"/><salute>lieber Richard,</salute> bitte<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chicken Sie mir mit den Büchern gleich den
                  <anchor type="commentary" xml:id="K_L01099-1"/><rs type="work" ref="#pmb50764" cert="low"><hi rend="latintype">Cicerone</hi></rs><note type="commentary" corresp="K_L01099-1">eventuell einer der vier Bände der von
                     <rs type="person" ref="#pmb50759">Gustav Ebe</rs> von
                     <date>1897</date>–<date>1901</date> unter dem Titel <rs type="work" ref="#pmb50764">Der deutsche Cicerone</rs> herausgegebenen Reihe von
                  Kunstführern</note> mit ja?</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>Arthur.</signed></closer><postscript><p><anchor type="commentary" xml:id="K_L01099-2"/><date>Mittwoch</date><note type="commentary" corresp="K_L01099-2"><ref target="1901-02-27" subtype="date-only" type="schnitzler-tagebuch"/>.
                  </note><space unit="chars" quantity="1"/><rs type="org" subtype="implied" ref="#pmb43143">Club</rs></p></postscript></div>
      </body>
