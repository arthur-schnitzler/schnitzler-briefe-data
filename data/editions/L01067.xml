      <body>
         <div type="address"><address><addrLine><pb facs="1900_AS_RBH_3_00011"/>Herrn Dr. <hi rend="latintype">Richard
                     Beer-Hofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb34401"><hi rend="latintype">Altaussee</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1900_AS_RBH_3_00012"/><salute>lieber Richard,</salute> ich möchte, we<c rendition="#gemination-n">nn</c>’s Ihnen
               recht i<c rendition="#langesS">s</c>t, am <anchor type="commentary" xml:id="K_L01067-1"/><date>Mittwoch</date><note type="commentary" corresp="K_L01067-1"><ref target="1900-08-08" subtype="See" type="schnitzler-tagebuch"/>.
               </note><space unit="chars" quantity="1"/><time>Mittag</time> zu Ihnen kommen; we<c rendition="#gemination-n">nn</c>’s Ihnen nicht
               pa<c rendition="#langesS">s</c><c rendition="#langesS">s</c>t, telegraf. Sie mir ab. Bei <date>So<c rendition="#gemination-n">nn</c>tag</date><space unit="chars" quantity="1"/><rs type="place" ref="#pmb30">Salzburg</rs> bleibts. <rs type="person" ref="#pmb2167"><hi rend="latintype">Salten</hi></rs> ko<c rendition="#gemination-m">mm</c>t vielleicht <anchor type="commentary" xml:id="K_L01067-2"/>direct nach <rs type="place" ref="#pmb38711">Schruns</rs><note type="commentary" corresp="K_L01067-2"><ref type="schnitzler-briefe" target="L03307" subtype="Cf"/>.
               </note>.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>Arthur.</signed></closer><postscript><p>(Ich verla<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e <rs type="place" ref="#pmb213">I<c rendition="#langesS">s</c>chl</rs><space unit="chars" quantity="1"/><date>Freitag</date>.)</p></postscript></div>
      </body>
