         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00097"/>Bitte <anchor type="commentary" xml:id="K_L01322-1"/>durchzule<c rendition="#langesS">s</c>en<note type="commentary" corresp="K_L01322-1">vermutlich <rs type="work" ref="#pmb30633">Elektra</rs></note> und dann zu<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chicken an meinen <rs type="person" ref="#pmb11737" subtype="implied">Papa</rs></p><p rend="inline"><rs ref="#pmb192623" type="place">III Salesianergasse 12</rs>.</p><closer><signed>Hugo.</signed></closer><postscript><p>(<rs type="work" ref="#pmb30633" subtype="implied">Aufführung</rs> an<c rendition="#langesS">s</c>cheinend
                     <anchor type="commentary" xml:id="K_L01322-2"/><date>Ende October</date><note type="commentary" corresp="K_L01322-2">Am <date>30. 10. 1903</date> wurde
                     <rs type="work" ref="#pmb30633">Elektra</rs> am <rs type="org" ref="#pmb45430">Kleinen Theater</rs> aufgeführt.</note>.)</p></postscript></div>
      </body>
