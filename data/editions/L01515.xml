   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1905_AS_RBH_1_00021"/><hi rend="pre-print">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="pre-print"><rs type="place" ref="#pmb168940">Wien, XVIII Spoettelgasse 7</rs>.</hi></addrLine></address><address><addrLine><pb facs="1905_AS_RBH_1_00020"/>Herrn <hi rend="latintype">Dr Richard
                     Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb173" type="place"><hi rend="latintype">Rodaun</hi></rs></addrLine><addrLine><rs type="place" ref="#pmb40101"><hi rend="latintype">Liesingerstr. 2</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1905_AS_RBH_1_00022"/><rs ref="#pmb50" type="place">Wien</rs>, <date when="1905-05-09">9. 5. 905</date></dateline></opener><p><salute>lieber Richard,</salute> heute er<c rendition="#langesS">s</c>t erfahre ich da<c rendition="#langesS">s</c>s Ihr <anchor type="commentary" xml:id="K_L01515-1"/><rs type="person" ref="#pmb34853" subtype="implied">Onkel</rs><note type="commentary" corresp="K_L01515-1"><rs type="person" ref="#pmb34853">Sigmund Beer</rs> war am <date>7. 5. 1905</date>
                  gestorben. Die Beerdigung fand am <date>9. 5. 1905</date> statt.</note> ge<c rendition="#langesS">s</c>torben
               i<c rendition="#langesS">s</c>t. Meine herzlich<c rendition="#langesS">s</c>te Theilnahme! Und hoffentlich auf<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr baldiges Wieder<c rendition="#langesS">s</c>ehn.</p><closer>Ihr<lb/><signed>Arthur.</signed></closer></div>
      </body>
