         <div type="address"><address><addrLine><pb facs="https://www.theatermuseum.at/de/object/bbc7c65a1d/"/>Herrn Hermann
                  Bahr</addrLine><addrLine><rs ref="#pmb165" type="place">Wien Ober St Veit</rs></addrLine><addrLine><rs ref="#pmb220" type="place">Veitli<c rendition="#langesS">s</c><c rendition="#langesS">s</c>enga<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="https://www.theatermuseum.at/de/object/bbc7c65a1d/"/><salute>lieber Hermann,</salute> möchte<c rendition="#langesS">s</c>t du<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>o gut<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein u mir den »<rs ref="#pmb29905" type="work">Ruf des
                  Lebens</rs>« recht bald zurück<c rendition="#langesS">s</c>enden? Ich brauche das Exemplar</p><closer>Herzlich<c rendition="#langesS">s</c>t dein<lb/><signed>Arthur</signed></closer><postscript><dateline><date>3/X 905</date></dateline></postscript></div>
      </body>
