      <body>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00202"/>freuen uns herzlich mit ihnen des
               grossen erfolges hoffen dass <rs ref="#pmb30203" type="work">bernhardi</rs>
               mindestens drei monate haft im <rs ref="#pmb208" type="place">kleinen theater</rs>
               erhaelt –</p><closer><signed>richard und paula</signed></closer></div>
      </body>
