         <div type="writingSession" n="1"><p rend="center"><handShift scribe="#pmb2121"/>Wir<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind in <rs ref="#pmb723" type="place"><hi rend="latintype">Welsberg</hi>-Waldbrunn</rs></p><p><pb facs="Wienbibliothek_H.I.N.-207636_rs"/><handShift scribe="#pmb2292"/><hi rend="latintype">Herzliche Grüsse</hi><space unit="chars" quantity="1"/><signed>Gerty Hofmannsthal</signed></p><p><handShift scribe="#pmb2121"/>Herzliche Grüße Ihnen und Fräulein <rs ref="#pmb5765" type="person"><hi rend="latintype">Mary</hi></rs>! Ihr<space unit="chars" quantity="1"/><signed>ArthSchnitzler</signed></p><p><handShift scribe="#pmb2173"/><hi rend="latintype">Auch von mir!</hi><space unit="chars" quantity="1"/><signed>OlgaSchnitzler</signed></p><p><handShift scribe="#pmb11740"/>Herzlich Gru<c rendition="#langesS">s</c>s. Wir<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind in wenigen Tagen in <rs ref="#pmb173" type="place">Rodaun</rs>.<space unit="chars" quantity="1"/><signed>HvHofmannsthal</signed></p></div>
      </body>
