         <div type="writingSession" n="1"><opener><dateline><pb facs="1904_AS_RBH_2_00038"/><rs type="place" ref="#pmb33"><hi rend="latintype">Lueg</hi></rs>, <date>28. 12. 904</date>.</dateline></opener><p><anchor type="commentary" xml:id="K_L01484-1"/><date>Montag</date><note type="commentary" corresp="K_L01484-1"><ref target="1905-01-02" type="schnitzler-tagebuch" subtype="See"/>.
               </note><space unit="chars" quantity="1"/><time>Abend</time> den <date>2.</date><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind wir (hoffentlich) in <rs type="place" ref="#pmb63">Hietzing</rs> bei <rs type="place" ref="#pmb304">Kuffner</rs>. Möchte
               Sie gern bald<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehen</p><closer>Ihr<lb/><signed>A.</signed></closer></div>
         <div type="writingSession" n="2"><closer><handShift scribe="#pmb2173"/>Herzliche Grüße! <lb/><signed>Olga.</signed></closer></div>
      </body>
