         <div type="address"><address><addrLine><pb facs="1901_AS_RBH_2_00013"/><del rend="strikethrough"><rs ref="#pmb1003" type="place">N.Oe.</rs></del></addrLine><addrLine>Hrn Dr. <hi rend="latintype">Rich Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb44278" type="place"><hi rend="latintype">Pörtschach</hi></rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb1110" type="place">Villa Arnstein</rs></hi></addrLine></address></div>
