      <body>
         <div type="address"><address><addrLine><pb facs="1914_AS_RBH_1_00019"/>Hrn <hi rend="latintype">Dr Richard Beerhofma<c rendition="#gemination-n">nn</c></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb34344">Weißenbach</rs>.</hi></addrLine><addrLine><hi rend="latintype">Am <rs ref="#pmb236" type="place">Attersee</rs></hi></addrLine><addrLine><rs type="place" ref="#pmb519"><hi rend="latintype">Oberoesterreic<supplied>h</supplied></hi></rs></addrLine><addrLine><rs type="place" ref="#pmb41240"><hi rend="latintype">Austria</hi></rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1914_AS_RBH_1_00018"/><hi rend="pre-print"><rs type="place" ref="#pmb12589">Celerina</rs> gegen <rs type="place" ref="#pmb34946">Pontresina</rs> ges.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1914_AS_RBH_1_00019"/>Aus <rs type="place" ref="#pmb34946">Pontresina</rs>
               (zu lärmen<unclear>d</unclear> – <hi rend="latintype">Hotel</hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>owohl als Ort)
               hieher <anchor type="commentary" xml:id="K_L02188-1"/>über<c rendition="#langesS">s</c>iedelt<note type="commentary" corresp="K_L02188-1"><ref target="1914-07-21" type="schnitzler-tagebuch" subtype="See"/>.
               </note> (<hi rend="latintype"><rs type="place" ref="#pmb1138">Cresta Palace, Celerina</rs></hi>) und höch<c rendition="#langesS">s</c>t befriedigt, grüßen wir Sie alle <pb facs="1914_AS_RBH_1_00018"/>herzlich<c rendition="#langesS">s</c>t. Eben<c rendition="#langesS">s</c>o <rs type="person" ref="#pmb12740">Gustav</rs>, der wohl
                  <unclear>und</unclear> bei Ihnen i<c rendition="#langesS">s</c>t?</p><closer>Ihr <signed>A.</signed></closer><postscript><dateline><date>25/7 914</date></dateline></postscript></div>
      </body>
