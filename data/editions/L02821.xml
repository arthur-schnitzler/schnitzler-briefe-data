   <text>
      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="HS.NZ85.1.3167_0046"/>Herrn Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb168934">IX. Frankga<c rendition="#langesS">s</c>se 1.</rs></hi></addrLine></address></div>
         <div type="image"><p><pb facs="HS.NZ85.1.3167_0045"/><hi rend="pre-print"><rs type="place" ref="#pmb51377">Wagner-Theater</rs>.</hi></p><p rend="center"><hi rend="pre-print">Gruss aus <rs type="place" ref="#pmb734">Bayreuth</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="HS.NZ85.1.3167_0045"/>Viele treue Grüße, <salute>lieb<c rendition="#langesS">s</c>ter Freund!</salute>
               Und bald<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehen wir uns in <anchor type="commentary" xml:id="K_L02821-1"/><hi rend="latintype"><rs type="place" ref="#pmb213">Ischl</rs></hi><note type="commentary" corresp="K_L02821-1">Zwischen <ref type="schnitzler-tagebuch" target="1897-08-19" subtype="date-only"/> und <ref type="schnitzler-tagebuch" target="1897-08-30" subtype="date-only"/> waren <rs type="person" ref="#pmb2121">Schnitzler</rs> und <rs type="person" ref="#pmb11485">Goldmann</rs> beide in <rs type="place" ref="#pmb213">Bad Ischl</rs>.</note>,
               nicht wahr? Nachrichten treffen mich bis Ende der Woche in <hi rend="latintype"><rs type="place" ref="#pmb401">Muenchen, Hotel Marienbad</rs></hi>.</p><closer>Dein <lb/><signed>Paul Goldmann</signed></closer></div>
      </body>
