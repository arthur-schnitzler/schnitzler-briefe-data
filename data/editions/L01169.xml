      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00022"/>D<hi rend="superscript">r</hi>
                  Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs ref="#pmb168934" type="place">IX Frankgasse 1</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00021"/><salute>Lieber Arthur!</salute> Machen Sie <anchor type="commentary" xml:id="K_L01169-1"/><rs type="org" ref="#pmb169320" subtype="implied">das</rs><note type="commentary" corresp="K_L01169-1"><ref type="schnitzler-briefe" target="L01167" subtype="Cf"/>. </note> mit <rs type="person" ref="#pmb11740">Hugo</rs> aus; ich schließe mich Euch an.
               Verständigen Sie mich dann.</p><closer>Herzlichst Ihr <lb/><signed>Richard</signed></closer></div>
      </body>
