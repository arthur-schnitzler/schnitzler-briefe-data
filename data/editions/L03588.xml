   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00050-V"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168815">XVIII. Sternwartestrasse 71</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00050-R"/><hi rend="pre-print"><rs type="place" ref="#pmb484">Zürich</rs>. <rs type="place" ref="#pmb143754">Großmünster</rs> und <rs type="place" ref="#pmb143757">Wasserkirche</rs></hi></p></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00050-V"/>Lieber,</salute></opener><p><rs type="place" ref="#pmb168">Berlin</rs> war diesmal sehr angenehm. Denn <anchor type="commentary" xml:id="K_L03588-1"/><rs type="person" ref="#pmb9445">Hans Rehmann</rs> gefiel mir ungemein<note type="commentary" corresp="K_L03588-1"><rs type="person" ref="#pmb9445">Hans Rehmann</rs> war der zukünftige Ehemann der
                  Tochter <rs type="person" ref="#pmb23915">Anna Katharina Salten</rs>.</note> und
               wir verstanden einander bald. Ich glaube, er ist ein wirklicher Mensch und bin
               natürlich froh! Hier muss ich bis <date when="1929-11-10">Sonntag</date> bleiben, um
               die <anchor type="commentary" xml:id="K_L03588-2"/><rs type="person" ref="#pmb12867">Johann-Strauss</rs>-Rede am <date when="1929-11-09">Samstag</date> zu wiederholen<note type="commentary" corresp="K_L03588-2">Am <date when="1929-11-04">4. 11. 1929</date> hatte <rs type="person" ref="#pmb2167">Salten</rs> im <rs type="place" ref="#pmb777">Stadttheater</rs>
                  eine Gedenkrede für <rs type="person" ref="#pmb12867">Johann Strauss</rs>
                  gehalten; am <date when="1929-11-09">9. 11. 1929</date> wurde die Veranstaltung
                  wiederholt.</note>.</p><closer>Herzlichst <lb/>Ihr <lb/><signed>Felix Salten</signed></closer><postscript><dateline><rs type="place" ref="#pmb484">Zürich</rs><space unit="chars" quantity="1"/><date when="1929-11-06">6. XI. 29</date></dateline></postscript></div>
      </body>
