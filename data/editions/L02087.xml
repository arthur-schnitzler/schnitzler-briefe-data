   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1912_AS_RBH_1_00025"/>Herrn u Frau</addrLine><addrLine>D<hi rend="superscript">r</hi> Richard Beer-Hofmann</addrLine><addrLine><rs type="place" ref="#pmb68">Wien XVIII</rs></addrLine><addrLine><rs type="place" ref="#pmb235251">Hasenauerstr. 59</rs>.</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1912_AS_RBH_1_00024"/><hi rend="pre-print">Sonnenuntergang am <rs type="place" ref="#pmb52262">Starnbergersee</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1912_AS_RBH_1_00025"/><handShift scribe="#pmb2121"/><salute>lieber Richard,</salute><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind Sie<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chon in <rs type="place" ref="#pmb50">Wien</rs>? Wie lang waren Sie in <rs type="place" ref="#pmb213">I<c rendition="#langesS">s</c>chl</rs>? Wie
               gehts Ihnen? Wir wollen hier bis <hi rend="latintype">circa</hi><space unit="chars" quantity="1"/><date>7.</date> bleiben. La<c rendition="#langesS">s</c><c rendition="#langesS">s</c>en Sie <del rend="strikethrough">uns</del> was von<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ich
               hören!</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr <signed>Arthur</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Herzliche Grüsse!</p><closer><signed>Olga.</signed></closer><postscript><p><rs type="place" ref="#pmb44493">Tutzing</rs>,<lb/><rs type="place" ref="#pmb51937">Hotel Simson</rs></p><dateline><date>30. Aug. 1912</date></dateline></postscript></div>
      </body>
