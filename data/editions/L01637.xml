   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1906_AS_RBH_1_00020"/>Dr. Richard</addrLine><addrLine>Beer-Hofmann</addrLine><addrLine><rs ref="#pmb68" type="place">Wien XVIII.</rs></addrLine><addrLine><rs type="place" ref="#pmb235251"> Hasenauerstraße <subst><del rend="strikethrough">56</del><add place="inline">59</add></subst></rs>.</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1906_AS_RBH_1_00019"/><hi rend="pre-print"><rs type="place" ref="#pmb51777">Semmering. Greiß</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1906_AS_RBH_1_00020"/>Grüaß Gott!</p><p>Ihr liabn <anchor type="commentary" xml:id="K_L01637-1"/>Nachbarsleutln<note type="commentary" corresp="K_L01637-1"><rs type="person" ref="#pmb10863">Richard</rs> und 
               <rs type="person" ref="#pmb10860">Paula Beer-Hofmann</rs>
               wohnten seit wenigen Tagen in dem für
               sie neu gebauten Haus in der <rs type="place" ref="#pmb235251">Hasenauerstraße</rs>, waren also nunmehr Nachbarn.</note>!</p><closer><signed>»D’r Turl«</signed><lb/><signed><handShift scribe="#pmb2173"/>»D’Olga</signed>«</closer><postscript><dateline><handShift scribe="#pmb2121"/><date>14. 11. 906</date>. </dateline></postscript></div>
         <div type="writingSession" n="2"><p><pb facs="1906_AS_RBH_1_00019"/>Is Ihnen <subst><del rend="overwritten">schon</del><add place="inline">scho</add></subst> besser? –</p><closer><signed>A.</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb10986"/>Ich brauche wohl nicht zu bemerken, dass dieser A. mir
               alle Hendln wegisst. Herzlichen Gruss jedennoch.</p><closer><signed>Brahm.</signed></closer></div>
      </body>
