      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00025"/><hi rend="latintype">Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><rs type="place" ref="#pmb50"><hi rend="latintype">Wien</hi></rs></addrLine><addrLine><rs ref="#pmb168934" type="place"><hi rend="latintype">IX. Franckgasse 1</hi></rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00026"/>lieber guter Arthur</salute></opener><p>es wäre mir aus ver<c rendition="#langesS">s</c>ch. Gründen <hi rend="underline" n="1"><c rendition="#langesS">s</c>ehr</hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chwer, morgen
               abend hineinzukommen und ich hoffe <rs ref="#pmb10986" type="person">Brahm</rs><space unit="chars" quantity="1"/><date>Dienstag</date> bei mir zu<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehen.</p><closer>Von Herzen Ihr<lb/><signed>Hugo.</signed></closer></div>
      </body>
