      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="Hs-30885,91_002"/>Hugo von Hofmannsthal</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb182" type="place">Paris</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb34022" type="place">192 Boulevard Haussman</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="Hs-30885,91_001"/><hi rend="pre-print"><rs ref="#pmb34020" type="place">Spalato – Split. Porta aurea</rs>.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="Hs-30885,91_001"/><salute>lieber Hugo,</salute> ich bin in <rs ref="#pmb873" type="place">Trie<c rendition="#langesS">s</c>t</rs> u
                  <rs ref="#pmb682" type="place">Ragu<c rendition="#langesS">s</c>a</rs> gewe<c rendition="#langesS">s</c>en, habe manches merkwürdige
               ge<c rendition="#langesS">s</c>ehen, bin heute in <rs ref="#pmb4231" type="place">Spalato</rs>, fahre Nachts nach
                  <rs ref="#pmb38096" type="place">Abazia</rs> und fühle, d<c rendition="#langesS">s</c>s ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr allein
               bin.</p><closer>Ihr <signed>Arthur</signed></closer></div>
      </body>
