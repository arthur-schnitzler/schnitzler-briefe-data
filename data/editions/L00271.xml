   <text>
      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="MS-SCHNITZLER-B-00043-B-00001-000-00104"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb412" type="place">I. Grillparzerstrasse 7</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="MS-SCHNITZLER-B-00043-B-00001-000-00103"/>lieber Arthur!</salute></opener><p>Der arme <anchor type="commentary" xml:id="K_L00271-1"/><rs ref="#pmb24651" type="person">Rudolf Schwarzk.</rs><note type="commentary" corresp="K_L00271-1">Die Todesanzeige (<bibl><rs ref="#pmb29351" type="org">Neue Freie Presse</rs>, Nr. 10.470,
                        <date>15. 10. 1893</date>, S. 14</bibl>.) belegt die Datierung.</note> i<c rendition="#langesS">s</c>t
               heute früh in <rs ref="#pmb43520" type="place">Meran</rs> ge<c rendition="#langesS">s</c>torben. <rs ref="#pmb12740" type="person">Gu<c rendition="#langesS">s</c>tav</rs> begräbt ihn dort. <rs ref="#pmb24648" type="person">Max</rs> i<c rendition="#langesS">s</c>t hier. Es i<c rendition="#langesS">s</c>t<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr traurig.</p><closer><signed>Hugo.</signed></closer></div>
      </body>
