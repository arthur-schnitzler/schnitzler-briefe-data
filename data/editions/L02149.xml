      <body>
         <div type="address"><address><addrLine><pb facs="1913_AS_RBH_1_00009"/>Herrn u. Frau</addrLine><addrLine>D<hi rend="superscript">r</hi> Richard Beer-Hofm<supplied>ann</supplied><space unit="chars" quantity="1"/><add place="below">aus <rs type="place" ref="#pmb50">Wien</rs></add></addrLine><addrLine><rs type="place" ref="#pmb259">Lido</rs> – <rs type="place" ref="#pmb462">Venedig</rs></addrLine><addrLine><rs type="place" ref="#pmb40983">Hôtel des Bains</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1913_AS_RBH_1_00008"/><hi rend="pre-print"><rs type="place" ref="#pmb45260">Insel Brioni i. d. Adria</rs></hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb52316">Val Catena</rs>.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1913_AS_RBH_1_00009"/>Wir fahren <anchor type="commentary" xml:id="K_L02149-1"/><date>Freitag</date><note type="commentary" corresp="K_L02149-1"><ref target="1913-08-22" type="schnitzler-tagebuch" subtype="Cf"/>.
               </note><space unit="chars" quantity="1"/><time>Abend</time> von hier nach <rs type="place" ref="#pmb462">Venedig</rs>, wollen
                  <date>Samstag</date><space unit="chars" quantity="1"/><time>Vormittag</time> an den <rs type="place" ref="#pmb259">Lido</rs> kommen und
               werden wol drüben speisen, – freuen uns herzlich, Sie zu sehen. Eine ev. Nachricht
               trifft uns in <rs type="place" ref="#pmb462">Venedig Grand Hôtel</rs>.</p><closer>Die herzlichsten Grüsse<lb/>Ihre <signed>Olga.</signed></closer><postscript><dateline><date>20. Aug 13</date>.</dateline></postscript></div>
         <div type="writingSession" n="2"><p><pb facs="1913_AS_RBH_1_00008"/><handShift scribe="#pmb2121"/><date>So<c rendition="#gemination-n">nn</c>tag</date> oder<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>päte<c rendition="#langesS">s</c>tens <anchor type="commentary" xml:id="K_L02149-2"/><date>Montag</date><note type="commentary" corresp="K_L02149-2"><ref target="1913-08-25" subtype="Cf" type="schnitzler-tagebuch"/>.
               </note> fahren wir nach <rs type="place" ref="#pmb886">Mailand</rs>, ev. <rs type="place" ref="#pmb1061">Engadin</rs> weiter.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr <signed>A.</signed></closer></div>
      </body>
