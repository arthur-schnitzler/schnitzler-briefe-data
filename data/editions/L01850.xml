      <body>
         <div type="address"><address><addrLine><pb facs="1909_AS_RBH_2_00025"/><hi rend="pre-print">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="pre-print"><rs type="place" ref="#pmb168940">Wien XVIII. Spoettelgasse 7</rs>.</hi></addrLine></address><address><addrLine><pb facs="1909_AS_RBH_2_00024"/><hi rend="latintype">Dr. Richard Beer-Hofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine></address></div>
         <div type="writingSession" n="1"><opener><seg type="letterhead"><pb facs="1909_AS_RBH_2_00026"/><hi rend="pre-print">Dr. Arthur Schnitzler</hi></seg><seg type="letterhead"><hi rend="pre-print"><rs type="place" ref="#pmb168940">Wien XVIII. Spoettelgasse 7</rs>.</hi></seg></opener><p><salute>lieber Richard,</salute> wir ko<c rendition="#gemination-m">mm</c>en heute nicht
               im <rs type="place" ref="#pmb74">T. P.</rs> nachtmahlen, <anchor type="commentary" xml:id="K_L01850-1"/><rs type="person" ref="#pmb2173">O.</rs> nicht ganz wohl<note type="commentary" corresp="K_L01850-1">Das undatierte Korrespondenzstück dürfte am <ref target="1909-06-26" type="schnitzler-tagebuch" subtype="date-only"/> verfasst
                  worden sein, da die beschriebenen Umstände mit den im <rs type="work" ref="#pmb33243">Tagebuch</rs> geschilderten übereinstimmen.</note>, ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chaue, we<c rendition="#gemination-n">nn</c>’s Ihnen recht i<c rendition="#langesS">s</c>t, zwi<c rendition="#langesS">s</c>chen <time>7</time> u
                  <time>½ 8</time> zu Ihnen.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>A.</signed></closer></div>
      </body>
