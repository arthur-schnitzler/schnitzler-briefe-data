   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1910_AS_RBH_1_00034"/>Hrn Dr. <hi rend="latintype">Richard Beer
                     Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb213">Ischl</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb405" type="place">Steinfeld<del rend="strikethrough"><unclear>gass</unclear></del> 6</rs></hi>.</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1910_AS_RBH_1_00033"/><hi rend="pre-print"><rs type="place" ref="#pmb2318">Partenkirchen</rs>. <rs type="place" ref="#pmb52102">St. Anton</rs> mit Blick auf <rs type="place" ref="#pmb52104">Dreithorspitze</rs>.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="center"><pb facs="1910_AS_RBH_1_00034"/><date when="1910-08-23">23. 8. 1910</date></dateline></opener><closer>Herzliche Grüße!<lb/><signed>A.</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Heute wurde am Krankenbett meiner <rs type="person" ref="#pmb2315" subtype="implied">Schwester</rs> viel von Ihnen gesprochen. Sie
               sagt immer wieder: »B.-H. ist von Euch allen der merscht Begabte!«</p><p>Von hier fahren wir <hi rend="underline" n="1">nicht</hi> nach <rs ref="#pmb213" type="place">Ischl</rs>, sondern <rs ref="#pmb146" type="place">Frankfurt</rs><space unit="chars" quantity="1"/><anchor type="commentary" xml:id="K_L01954-1"/><rs ref="#pmb31311" type="work">Liebelei Opern-Première</rs><note type="commentary" corresp="K_L01954-1"><ref target="1910-09-18" type="schnitzler-tagebuch" subtype="See"/>.
               </note>, vorher <rs ref="#pmb882" type="place">Heidelberg</rs>.</p><closer>Herzlichste Grüsse Ihnen Allen! <signed>O. S.</signed></closer></div>
      </body>
