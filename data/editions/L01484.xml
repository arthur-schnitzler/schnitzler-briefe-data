         <div type="address"><address><addrLine><pb facs="1904_AS_RBH_2_00039"/><hi rend="latintype">Herrn Dr. Richard Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb173">Rodaun</rs></hi><space unit="chars" quantity="1"/><add place="margin"><hi rend="latintype">bei</hi><space unit="chars" quantity="1"/><rs type="place" ref="#pmb50">Wien</rs>, <rs type="org" ref="#pmb41943">Südbahn</rs></add></addrLine><addrLine><rs ref="#pmb40101" type="place"><hi rend="latintype">Liesingerstraße 2</hi></rs></addrLine></address></div>
