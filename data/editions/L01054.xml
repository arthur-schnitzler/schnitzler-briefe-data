      <body>
         <div type="address"><address><addrLine><pb facs="1900_AS_RBH_2_00032"/>Herrn <hi rend="latintype">Dr. Richard</hi></addrLine><addrLine><hi rend="latintype">Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb34401" type="place">Altaussee</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb17" type="place">Steier<damage agent="paperloss"><unclear>ma</unclear></damage>rk</rs></hi>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline><seg rend="left"><pb facs="1900_AS_RBH_2_00034"/><rs ref="#pmb44982" type="place"><hi rend="latintype">Curhaus, Reichenau N.Oe.</hi></rs></seg><seg rend="right"><date when="1900-07-14">14. 7. 900</date></seg></dateline></opener><p><salute>lieber Richard,</salute> es i<c rendition="#langesS">s</c>t unglaublich, d<c rendition="#langesS">s</c>s Sie mir keine Silbe<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chreiben. Haben Sie meinen Brief nicht erhalten? Ihr <signed>Arthur</signed></p></div>
      </body>
