   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1900_AS_RBH_2_00018"/>Herrn <hi rend="latintype">Dr. Rich.
                     Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb34401" type="place">Altaussee</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1900_AS_RBH_2_00020"/><salute>Lieber Richard,</salute> bitte be<c rendition="#langesS">s</c>tellen Sie mir
               bei <rs type="place" ref="#pmb40256">Bru<c rendition="#gemination-n">nn</c>thaler</rs> ein
                  Zi<c rendition="#gemination-m">mm</c>er. Ich beab<c rendition="#langesS">s</c>ichtige <date>Donnerstag</date> früh
               nach <rs ref="#pmb213" type="place">I<c rendition="#langesS">s</c>chl</rs> zu fahren, dort <rs type="person" ref="#pmb9233 #pmb11701">Hir<c rendition="#langesS">s</c>chf.s</rs> zu be<c rendition="#langesS">s</c>uchen u zu übernachten, <hi n="2" rend="underline"><date>Freitag</date></hi><space unit="chars" quantity="1"/><hi rend="underline" n="1">früh</hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>päte<c rendition="#langesS">s</c>tens Mittag in <rs ref="#pmb34401" type="place">Altau<c rendition="#langesS">s</c><c rendition="#langesS">s</c>ee</rs><space unit="chars" quantity="1"/><pb facs="1900_AS_RBH_2_00021"/>zu<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein wo ich bis <date>So<c rendition="#gemination-n">nn</c>tag</date> früh bleibe. Weiteres mündlich.</p><closer>Auf Wieder<c rendition="#langesS">s</c>ehn. Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr <signed>Arthur</signed></closer><p><date>26 6 900</date>.</p></div>
      </body>
