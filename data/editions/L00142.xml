   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1892_AS_RBH_2_00017"/><hi rend="latintype">Herrn Dr Rich. Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb50" type="place">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb190427" type="place">I Wollzeile 15</rs></hi>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1892_AS_RBH_2_00019"/><date>10. 12. 92</date></dateline><salute>Lieber Richard,</salute></opener><p>ich habe al<c rendition="#langesS">s</c>o dem Herrn <rs ref="#pmb12740" type="person"><hi rend="latintype">Schwarzkopf</hi></rs> ge<c rendition="#langesS">s</c>chrieben, da<c rendition="#langesS">s</c>s wir morgen um <time>5 Uhr Nachmittag</time> bei Ihnen<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein
               dürften.</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr<signed>Arthur.</signed></closer></div>
      </body>
