   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1905_AS_RBH_1_00018"/>Richard Beerhofmann</addrLine><addrLine><hi rend="stamp"><rs type="place" ref="#pmb173">Rodaun</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1905_AS_RBH_1_00018"/>Gratulire von Herzen zum <rs ref="#pmb42042" type="org">Schillerpreis</rs> freuten
               uns sehr möchte zur <rs ref="#pmb30233" type="work">Charolais</rs>premiéren zwei
               Sitze möglichst erste Reihe bitte Nachricht wann wo abholbar viele Grüsse von Haus zu
               Haus</p><closer>= Ihr <signed>Arthur</signed></closer></div>
      </body>
