         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00001-000-00377"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine>sehr bekannt</addrLine><addrLine>in <handShift scribe="#pmb10863"/><space unit="chars" quantity="1"/><rs ref="#pmb483" type="place">Reichenau</rs></addrLine><addrLine><rs type="place" ref="#pmb44982">Kurhaus</rs></addrLine><addrLine><rs ref="#pmb1003" type="place">N. Ö.</rs></addrLine></address></div>
