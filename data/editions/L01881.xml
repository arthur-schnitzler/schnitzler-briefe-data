         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="1909_AS_RBH_2_00007"/>Dr. Richard Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb68">Wien XVIII</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb235251" type="place"><hi rend="latintype">Hasenauerstr 59</hi></rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1909_AS_RBH_2_00006"/><date><anchor type="commentary" xml:id="K_L01881-1"/>Montag <hi rend="latintype">ersten</hi><note type="commentary" corresp="K_L01881-1"><ref target="pmb46528" subtype="See" type="schnitzler-kultur"/>.
                  </note></date>, <time>Nm. 5 ½</time> möcht ich <rs ref="#pmb29937" type="work">Medardus</rs><space unit="chars" quantity="1"/><rs type="event" subtype="implied" ref="#pmb46528">vorle<c rendition="#langesS">s</c>en</rs>. Bitte Mittheilg, recht bald, ob<damage><unclear>’s</unclear></damage> Ihnen pa<c rendition="#langesS">s</c><c rendition="#langesS">s</c>t.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>Arthur</signed></closer></div>
