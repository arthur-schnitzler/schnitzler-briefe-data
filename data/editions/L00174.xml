      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="MS-SCHNITZLER-B-00043-B-00001-000-00085"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb50" type="place">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb412" type="place">I. Grillparzerstrasse 7</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="MS-SCHNITZLER-B-00043-B-00001-000-00086"/><hi rend="underline" n="1">II</hi></dateline><salute>lieber Arthur.</salute></opener><p><rs ref="#pmb2450" type="person">Fels</rs> war gerade bei mir. Bitte<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chreiben Sie
               mir ra<c rendition="#langesS">s</c>ch<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>eine Adre<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e, damit ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>owohl die<c rendition="#langesS">s</c>en leider ver<c rendition="#langesS">s</c>äumten Be<c rendition="#langesS">s</c>uch erwidern
               als ihm etwas Wein und Wä<c rendition="#langesS">s</c>che<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chicken kann.</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/><signed>Loris.</signed></closer></div>
      </body>
