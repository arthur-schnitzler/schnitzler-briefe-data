   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00003-000-00187"/>Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb168815">XVIII Sternwartestrasse 71</rs></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb41240">Autriche</rs></addrLine></address></div>
         <div type="image"><p><pb facs="MS-SCHNITZLER-B-00043-B-00003-000-00188"/><hi rend="pre-print"><foreign xml:lang="fr"><rs type="place" ref="#pmb36443"><hi rend="capitals">Avignon</hi></rs> – N.-D des Doms (<rs type="place" ref="#pmb44589">Cathédrale</rs>) Tour
                     Campane et partie du Palais construite à l’avènement du Pape <rs type="person" ref="#pmb44591">Jean XXII</rs> (<date>1316</date>), sur l’emplacement de
                     l’Eglise St-Etienne. <rs type="person" ref="#pmb44592">Benoit XII</rs>,
                     (<date>1335</date>–<date>1342</date>) sur les plans de Pierre Obrerie
                     architecte français compléta l’œuvre de son prédécesseur. Cette partie du
                     monument renferme aujourd’hui les Archives départementales.</foreign></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00043-B-00003-000-00187"/>Da ist schon die erste Karte mit
               vielen Grüßen u. Gedanken!</p><closer><signed>Hugo.</signed></closer><postscript><dateline><rs ref="#pmb36443" type="place">Avignon</rs><space unit="chars" quantity="1"/><date>3 III 1925</date>.</dateline></postscript></div>
      </body>
