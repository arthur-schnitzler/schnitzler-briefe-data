         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00008"/><hi rend="latintype">Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><rs type="place" ref="#pmb50"><hi rend="latintype">Wien</hi></rs></addrLine><addrLine><rs ref="#pmb168934" type="place"><hi rend="latintype">IX. Frankgasse 1</hi></rs>.</addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb41240">Austria</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00007"/><hi rend="pre-print"><rs ref="#pmb259" type="place">Bagni di Lido</rs></hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb462">Venezia</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00007"/>Wir thun <rs type="place" ref="#pmb259" subtype="implied">hier</rs><space unit="chars" quantity="1"/>See-baden und ich le<c rendition="#langesS">s</c>e dazu <rs ref="#pmb31585" type="work">die natürliche Tochter</rs>. Hoffentlich liegt in <rs ref="#pmb173" type="place">Rodaun</rs> in 8 Tagen eine Zeile von Ihnen. Viele Grüße von <rs ref="#pmb2292" type="person">Gerty</rs>. Von Herzen Ihr</p><closer><signed>Hugo</signed></closer></div>
      </body>
