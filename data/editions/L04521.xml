      <body>
         <div type="image"><p rend="center"><pb facs="HS00048772X_0355"/><hi rend="pre-print"><rs type="place" ref="#pmb667">Partenkirchen</rs>
                  mit <rs type="place" ref="#pmb47581">Zugspitze</rs>.</hi></p></div>
         <div type="address"><address><addrLine><pb facs="HS00048772X_0356"/>Herrn</addrLine><addrLine>Gu<c rendition="#langesS">s</c>tav Schwarzkopf</addrLine><addrLine><rs type="place" ref="#pmb51">Wien I</rs></addrLine><addrLine><rs type="place" ref="#pmb207301"><hi rend="latintype">Tiefer Graben</hi> 17</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p>Herzlich<c rendition="#langesS">s</c>t Ihr</p><closer><signed>Arthur</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Das <rs type="person" ref="#pmb2315">Lisl</rs> ist dicker
               geworden und sieht so gut aus, wie
               seit langem nicht. Gott sei Dank.</p><closer>Herzliche Grüsse<lb/><signed>Olga Schnitzler</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb2315"/>Und Ihre alte</p><closer><signed>Lise St.</signed></closer></div>
         <div type="writingSession" n="4"><postscript><dateline><handShift scribe="#pmb2121"/><pb facs="HS00048772X_0355"/><date>14.11.911</date></dateline></postscript></div>
      </body>
