         <div type="address"><address><addrLine><pb facs="1910_AS_RBH_2_00029"/><hi rend="latintype">Herrn Dr. Richard</hi></addrLine><addrLine><hi rend="latintype">Beer-Hofma<c rendition="#gemination-n">nn</c></hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1910_AS_RBH_2_00028"/><date when="1910-12-27">27/12</date></dateline><salute>lieber Richard,</salute></opener><p>we<c rendition="#gemination-n">nn</c> irgend möglich werd ich gegen <time>6</time> ins <rs ref="#pmb819" type="place">Pucher</rs> ko<c rendition="#gemination-m">mm</c>en. Herzl
               Dank. Ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>age i<c rendition="#gemination-m">mm</c>r man<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>oll entweder kein Telephon oder
               keine Freunde haben.</p><closer>Ihr<lb/><signed>A.</signed></closer></div>
      </body>
