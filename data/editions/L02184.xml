         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00218"/>Herrn</addrLine><addrLine>D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs ref="#pmb68" type="place">Wien XVIII</rs></addrLine><addrLine><rs ref="#pmb168815" type="place">Sternwartestrasse 71</rs></addrLine></address></div>
