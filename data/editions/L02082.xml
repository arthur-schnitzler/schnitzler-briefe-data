      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="1912_AS_RBH_1_00022"/>Herrn Dr.</hi></addrLine><addrLine><hi rend="latintype">Richard Beerhofmann</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb44374">St Moritz</rs></hi></addrLine><addrLine><hi rend="latintype">im <rs type="place" ref="#pmb1061">Engadin</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb51935">Waldhaus</rs>.</hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1912_AS_RBH_1_00021"/><hi rend="pre-print"><rs type="place" ref="#pmb45260">Insel Brioni i. d. Adria</rs>.</hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb52316">Val Catena</rs>.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1912_AS_RBH_1_00022"/><salute>lieber Richard,</salute> un<c rendition="#langesS">s</c>er Plan i<c rendition="#langesS">s</c>t am <date>20</date> od
                  <date>21.</date> über die <rs type="place" ref="#pmb40306">ital Seen</rs> nach <rs type="place" ref="#pmb40516"><hi rend="latintype">Sils Maria</hi></rs>, dort bis <date>Ende Augu<c rendition="#langesS">s</c>t</date>, da<c rendition="#gemination-n">nn</c><space unit="chars" quantity="1"/><rs type="place" ref="#pmb45258"><hi rend="latintype">München</hi></rs>, (<rs type="place" ref="#pmb44493"><hi rend="latintype">Tutzing</hi></rs>) <hi rend="latintype">circa</hi> 8 Tage; u <hi rend="latintype">direct</hi> von
               dort <rs type="place" ref="#pmb50">Wien</rs>. Vielleicht trifft man<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ich in <rs type="place" ref="#pmb45258">München</rs> (<anchor type="commentary" xml:id="K_L02082-1"/>Sitze be<c rendition="#langesS">s</c>orgt?<note type="commentary" corresp="K_L02082-1"><ref type="schnitzler-briefe" subtype="See" target="L00478"/>, <ref type="schnitzler-briefe" target="L02554"/>. </note>) Wie lange bleibt <rs type="person" ref="#pmb2496">Kaufma<c rendition="#gemination-n">nn</c></rs> im <rs type="place" ref="#pmb1061">Engadin</rs>?</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr <signed>A.</signed></closer></div>
      </body>
