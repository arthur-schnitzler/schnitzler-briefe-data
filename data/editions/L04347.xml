   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0331_CUL_FOTO_CUT_1764"/>Herrn</addrLine><addrLine>Dr. Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168934">IX. Franga<c rendition="#langesS">s</c>se 1</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0331_CUL_FOTO_CUT_1765"/>Wir haben soeben mit Begeisterung Ihr
            Wohl und das der »Literatenseelen« ausgebracht, was wir Ihnen nicht vorenthalten wollen.</p><closer>Herzliche Grüsse<lb/><signed>Idus Fulda</signed></closer></div>
         <div type="writingSession" n="2"><closer><handShift scribe="#pmb342723"/>eine <signed>Christine</signed></closer><postscript><p><handShift scribe="#pmb2537"/>und was für Eine!</p></postscript></div>
         <div type="writingSession" n="3"><closer><signed><handShift scribe="#pmb11485"/>Paul Goldmann.</signed></closer></div>
         <div type="writingSession" n="4"><closer><handShift scribe="#pmb342725"/>Die Sie sehr verehrende <anchor type="commentary" xml:id="K_L04347-1"/>Wirtin<note type="commentary" corresp="K_L04347-1"><rs type="person" ref="#pmb342725">Emma Friedmann</rs>, <ref type="schnitzler-briefe" target="L03095" subtype="cf"/>.</note>.</closer></div>
         <div type="writingSession" n="5"><closer><handShift scribe="#pmb9138"/>Herzlichen Gruß von Ihrem <signed>Hans Olden</signed></closer></div>
         <div type="writingSession" n="6"><closer><handShift scribe="#pmb7253"/>Schließlich auch von dem Ihnen unbekannten Wirth <anchor type="commentary" xml:id="K_L04347-2"/>von’s Janze<note type="commentary" corresp="K_L04347-2">dialektal: vom Ganzen</note>: <signed>D<hi rend="superscript">r</hi> AlfredFriedmann</signed></closer></div>
      </body>
