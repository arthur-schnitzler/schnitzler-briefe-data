      <body>
         <div type="address"><address><addrLine><pb facs="1907_AS_RBH_1_00029"/><hi rend="latintype">Dr. Richard Beerhofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb235251">Hasenauerstr 59</rs>.</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb41240">Austria</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1907_AS_RBH_1_00028"/><hi rend="pre-print"><rs type="place" ref="#pmb53762">Lago di Misurina</rs> (1755 m), <rs type="place" ref="#pmb53764" subtype="implied">Grand Hôtel</rs>.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1907_AS_RBH_1_00029"/><date><anchor type="commentary" xml:id="K_L01699-1"/>12. 8. 907<note type="commentary" corresp="K_L01699-1">Im <rs type="work" ref="#pmb33243">Tagebuch</rs> wird der Ausflug erst für den <ref target="1907-08-13" type="schnitzler-tagebuch" subtype="date-only"/> erwähnt, weswegen dieses Datum
                        falsch sein dürfte.</note></date></dateline></opener><p>In <anchor type="commentary" xml:id="K_L01699-2"/>Erinnerung<note type="commentary" corresp="K_L01699-2"><ref target="1898-08-06" type="schnitzler-tagebuch" subtype="See"/>.
               </note> und herzlich<c rendition="#langesS">s</c>t,</p><closer>Ihr<lb/><signed>Arthur</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Die herzlichsten Grüsse!</p><closer><signed>Olga.</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb2121"/>Auf einer Fußwanderung <rs type="place" ref="#pmb44317"><hi rend="latintype">Schluderbach</hi></rs><space unit="chars" quantity="1"/><rs type="place" ref="#pmb34199"><hi rend="latintype">Cortina</hi></rs></p><p>Morgen wieder in <rs type="place" ref="#pmb428"><hi rend="latintype">Welsberg</hi></rs>. –</p></div>
      </body>
