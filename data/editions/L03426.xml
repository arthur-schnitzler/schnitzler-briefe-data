         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00039-V"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb68">Wien XVIII.</rs></addrLine><addrLine><rs type="place" ref="#pmb168940">Spöttelga<c rendition="#langesS">s</c>se 7</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00039-R"/><hi rend="pre-print">Gruss aus <rs type="place" ref="#pmb147545">Königs-Wusterhausen</rs></hi></p><p rend="center"><hi rend="pre-print">Historisches Buffet aus der Zeit der Königin <rs type="person" ref="#pmb114982">Louise</rs></hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb147548">Pfuhl’s Hôtel</rs></hi></p><p rend="center"><hi rend="pre-print">Parthie aus dem Park</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00039-R"/><salute>Lieber,</salute> ja, <anchor type="commentary" xml:id="K_L03426-1"/>krank<note type="commentary" corresp="K_L03426-1"><ref type="schnitzler-briefe" target="L03430" subtype="See"/>.
               </note> war ich: aber es geht wieder besser. Brief folgt.</p><closer>herzlichst für Sie <c rendition="#kaufmannsund"/><space unit="chars" quantity="1"/><rs type="person" ref="#pmb2173">Olga</rs><lb/>Ihr <signed>Salten</signed><lb/><handShift scribe="#pmb23918"/><signed>Ottilie</signed></closer></div>
         <div type="writingSession" n="2"><closer><handShift scribe="#pmb11324"/>Viele Grüße von Ihrem <signed>SFischer</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb2657"/><hi rend="latintype">Hedwig Fischer</hi> grüßt Sie u. Ihre <rs type="person" subtype="implied" ref="#pmb2173">Frau</rs>.</p></div>
         <div type="writingSession" n="4"><p><handShift scribe="#pmb147550"/>Eine <anchor type="commentary" xml:id="K_L03426-2"/>Verehrerin<note type="commentary" corresp="K_L03426-2">nicht
                  identifiziert</note> grüßt auch noch herzlich.</p></div>
      </body>
