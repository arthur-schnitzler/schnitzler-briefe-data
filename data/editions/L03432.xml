   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00045-V"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb41010">Kurhaus</rs></addrLine><addrLine><rs type="place" ref="#pmb959">Marienlyst</rs> bei <rs type="place" ref="#pmb36300">Kopenhagen</rs></addrLine><addrLine><rs type="place" ref="#pmb43570">Dänemark</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00045-R"/><hi rend="pre-print">Gruss aus dem <rs type="place" ref="#pmb147403">zoologischen
                     Garten</rs> zu <rs type="place" ref="#pmb168">Berlin</rs>.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="left"><pb facs="MS-SCHNITZLER-B-00089-B-00001-000-00045-R"/><date when="1906-07-27">27. 7. 06</date>.</dateline><seg><time>Abds</time>.</seg></opener><p><salute>Lieber,</salute><space unit="chars" quantity="1"/><date when="1906-07-27">heute</date> aus <rs type="place" ref="#pmb50">Wien</rs> zurück, mit Otti
               hier Rendezvous. <date when="1906-07-31">Dienstag</date><space unit="chars" quantity="1"/><time>früh</time> ab <rs type="place" ref="#pmb64659">Heringsdorf</rs>, <rs type="place" ref="#pmb36300">Kopenhagen</rs>, sind wir <date when="1906-08-02">Donnerstag</date> in <rs type="place" ref="#pmb959">Marienlyst</rs>; freuen uns
               auf das <anchor type="commentary" xml:id="K_L03432-1"/>Wiedersehen<note type="commentary" corresp="K_L03432-1"><ref type="schnitzler-tagebuch" target="1906-08-02" subtype="See"/>.
               </note> und grüßen Sie <rs type="person" subtype="implied" ref="#pmb2173">Beide</rs>
               und <rs type="person" ref="#pmb12692">Heini</rs> herzlichst <lb/><signed>Salten</signed></p></div>
         <div type="writingSession" n="2"><postscript><p><handShift scribe="#pmb23918"/>Viele herzliche Grüße <signed>Otti S.</signed></p></postscript></div>
      </body>
