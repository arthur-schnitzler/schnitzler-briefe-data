      <body>
         <div type="address"><address><addrLine><pb facs="1909_AS_RBH_1_00019"/>Hrn <hi rend="latintype">Dr. Richard
                     Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb68">Wien XVIII</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb235251">Hasenauerstr 59</rs></hi></addrLine><addrLine><hi rend="latintype">(nachzusenden)</hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1909_AS_RBH_1_00018"/><hi rend="pre-print"><rs type="place" ref="#pmb714">Hôtel Edlacherhof.</rs></hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb470">Edlach bei Reichenau, N.-Oe.</rs>, 520 m.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1909_AS_RBH_1_00019"/><date>18. <unclear>7. 09</unclear></date></dateline></opener><p><salute>lieber Richard,</salute><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>tatt in <rs type="place" ref="#pmb50">Wien</rs><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein Sie vom <date>1.</date>–<date>15. 8.</date> lieber in <rs type="place" ref="#pmb470">Edlach</rs>. <rs type="person" ref="#pmb12692">Heini</rs> ko<c rendition="#gemination-m">mm</c>t er<c rendition="#langesS">s</c>t übermorgen zu uns heraus. Wie gehts Ihnen
               Allen?</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr <signed>Arthur</signed></closer></div>
      </body>
