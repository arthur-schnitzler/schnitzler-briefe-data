   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1899_AS_RBH_2_00042"/><hi rend="latintype">Herrn Dr. Richard Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb946" type="place"><hi rend="latintype">Vahrn</hi></rs> bei <hi rend="latintype"><rs ref="#pmb43040" type="place">Brixen</rs></hi></addrLine><addrLine><rs ref="#pmb423" type="place"><hi rend="latintype">Tirol</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1899_AS_RBH_2_00043"/><salute>lieber Richard,</salute> eben i<c rendition="#langesS">s</c>t ein Brief an Sie nach <rs ref="#pmb41430" type="place"><hi rend="latintype">Sachsenburg</hi></rs> abgegangen. Er enthält nichts wichtiges; nur d<subst><del rend="overwritten"><unclear>en Um<c rendition="#langesS">s</c>tand</unclear></del><add place="inline">ie Bitte</add></subst>, Sie möchten mir nach <rs ref="#pmb45258" type="place">München</rs><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chreiben, wo ich <date>Mittwoch</date> u
                  <date>Donnerstag</date><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein will.</p><closer>Herzlich Ihr <signed>A.</signed></closer></div>
      </body>
