   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1894_AS_RBH_1_00024"/>Hrn <hi rend="latintype">Dr. Richard
                     Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><rs ref="#pmb190427" type="place"><hi rend="latintype">I. Wollzeile 15</hi></rs></addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="1894_AS_RBH_1_00023"/>Lieber Richard,</salute></opener><p>Seien Sie<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>o gut,<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>enden Sie an <rs ref="#pmb2450" type="person"><hi rend="latintype">Fels</hi></rs><space unit="chars" quantity="1"/><rs ref="#pmb33993" type="place">XVIII., <hi rend="latintype">Exnergasse 3</hi></rs>, Thür 22, 3. Stock etwas Geld – ich bin am Ende meiner Kräfte.</p><closer>Herzl. Gru<c rendition="#langesS">s</c>s<lb/><signed>Arthur</signed></closer></div>
      </body>
