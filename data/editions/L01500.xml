   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00081"/>Herrn</addrLine><addrLine>D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168940">XVIII Spöttelgasse 7</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00082"/><hi rend="pre-print"><rs type="person" ref="#pmb11209">Albrecht Dürer</rs>-Serie</hi></p><p rend="center"><hi rend="pre-print"><rs type="work" ref="#pmb46093">Das kleine Pferd</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00082"/>Zur <anchor type="commentary" xml:id="K_L01500-1"/><rs type="work" ref="#pmb30233" subtype="implied">Première</rs><note type="commentary" corresp="K_L01500-1"><rs type="work" ref="#pmb30233">Der Graf von Charolais</rs> hatte am <date>10. 2. 1905</date> am <rs type="org" ref="#pmb48177">Münchner Residenztheater</rs>
                   Premiere.</note> gehen
               weder <rs ref="#pmb10860" type="person">Paula</rs> noch ich. Die Generalprobe war zu
               schön. <anchor type="textConst" xml:id="T_L01500-1"/>↑ ist kein
                  Hoftheatermitglied<note type="textConst" corresp="T_L01500-1">Der Pfeil zeigt auf
                  das Pferdemotiv der Karte.</note>. <signed>Richard</signed></p></div>
      </body>
