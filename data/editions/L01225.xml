      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00051"/>Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb30" type="place">Salzburg</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb230">Hôtel oesterr. Hof</rs></hi></addrLine></address></div>
