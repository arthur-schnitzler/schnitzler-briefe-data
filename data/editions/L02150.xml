   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1913_AS_RBH_1_00012"/>Hrn u Frau</addrLine><addrLine><hi rend="latintype">Rich. Beerhofmann</hi></addrLine><addrLine>aus <rs type="place" ref="#pmb50">Wien</rs>,</addrLine><addrLine>d. Z. <rs type="place" ref="#pmb259"><hi rend="latintype">Lido</hi></rs></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb462">Venedig</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb40983">Grd Hotel des bains</rs></hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1913_AS_RBH_1_00011"/><hi rend="pre-print"><rs type="place" ref="#pmb34108">Maloja</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1913_AS_RBH_1_00012"/>Herzlich<c rendition="#langesS">s</c>te Grüße. Wir<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind vom <rs type="place" ref="#pmb1061">Engadin</rs> ganz entzückt. Der angenehmen <rs type="place" ref="#pmb259"><hi rend="latintype">Lido</hi></rs> Stunden gern gedenkend</p><closer>Ihr <signed>A.</signed></closer><postscript><dateline><rs type="place" ref="#pmb34108">Maloja</rs><space unit="chars" quantity="1"/><date>27/8 91<unclear>3</unclear></date></dateline></postscript></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Hier ist die Welt besonders schön! Alles Herzliche,</p><closer>Ihre <signed>Olga.</signed></closer></div>
      </body>
