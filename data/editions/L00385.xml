   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00096"/><hi rend="pre-print">A</hi>n Herrn D<hi rend="superscript">r</hi> Arthur
                  Schnitzler</addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><rs ref="#pmb168934" type="place">IX Frankgasse 1</rs></addrLine><addrLine><rs ref="#pmb41240" type="place">Austria</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00095"/><salute>Lieber Arthur!</salute> II. Nu<c rendition="#gemination-m">mm</c>er der <rs ref="#pmb40042" type="work">Zukunft</rs> erhalten, erste nicht; bitte I u III <rs ref="#pmb595" type="place"><hi n="1" rend="underline">Neapel</hi></rs><space unit="chars" quantity="1"/><hi rend="underline" n="1">a posta ferma</hi> oder <rs ref="#pmb623" type="place">Hôtel Hassler</rs> zu adressiren. Möchte von <hi n="1" rend="underline">Ihnen</hi><space unit="chars" quantity="1"/><rs ref="#pmb30397" type="work">Schmetterlingsschlacht</rs> »hören«. Ich bin
                  <date>5. Nov</date> in <rs ref="#pmb50" type="place">Wien</rs>.</p><closer>Herzlichst Ihr<lb/><signed>Richard</signed></closer><postscript><dateline><date>Mittwoch</date>. <subst><del rend="overwritten">M</del><add place="inline">A</add></subst><time>bends</time>. <rs ref="#pmb595" type="place">Neapel</rs>.</dateline></postscript></div>
      </body>
