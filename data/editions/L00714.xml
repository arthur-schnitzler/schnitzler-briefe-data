         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00232"/>arthur schnitzler <rs type="place" ref="#pmb59">win 9</rs><space unit="chars" quantity="1"/><rs ref="#pmb168934" type="place">frankg 1</rs></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00232"/>wfr <rs type="place" ref="#pmb213">ischl</rs> 3549 27 <date>7</date><space unit="chars" quantity="1"/><time>10/38</time>+</dateline></opener><p>konte gestern <rs type="person" ref="#pmb16560" subtype="implied">fluechtyg
                  sprechn</rs> kain bsondrer grund langewejle wahrschainlych ich rejse morgn <rs ref="#pmb30" type="place">salzburg</rs> bin <date>mittwoch</date> oder
                  <date>donerstag</date> in <rs type="place" ref="#pmb50">win</rs> herzlychst
               rychard=</p></div>
