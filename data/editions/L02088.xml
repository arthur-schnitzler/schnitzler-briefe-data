         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00002-000-00196"/>Herrn</addrLine><addrLine>Arthur Schnitzler</addrLine><addrLine><rs ref="#pmb44493" type="place">Tutzing</rs></addrLine><addrLine><rs ref="#pmb52262" type="place">Starnbergersee</rs></addrLine><addrLine><rs ref="#pmb51937" type="place">Hôtel Simson</rs></addrLine></address></div>
