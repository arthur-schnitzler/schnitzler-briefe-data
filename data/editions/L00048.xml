         <div type="writingSession" n="1"><p rend="right"><pb facs="3227_Schnitzler_Märchen_001"/>Herrn Dr. v. <hi rend="latintype">Hofma<c rendition="#gemination-n">nn</c>sthal</hi></p><p rend="right">verehrungsvoll</p><closer><signed>ArthSch.</signed></closer><space dim="vertical" unit="line" quantity="1"/><p><hi rend="pre-print"><hi rend="underline" n="1">Manu<c rendition="#langesS">s</c>kript.</hi></hi></p><p rend="center"><hi rend="pre-print"><rs type="work" ref="#pmb29823"><hi rend="bold"><hi rend="spaced-out">Das Märchen</hi></hi></rs>.</hi></p><p rend="center"><hi rend="pre-print">Schau<c rendition="#langesS">s</c>piel in drei Aufzügen</hi><lb/><hi rend="pre-print">von</hi><lb/><hi rend="pre-print"><hi rend="bold">Arthur Schnitzler.</hi></hi></p><space dim="vertical" unit="line" quantity="1"/><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb50"><hi rend="bold">Wien</hi></rs><space unit="chars" quantity="1"/><date><anchor type="commentary" xml:id="K_L00048-1"/><hi rend="bold">1891</hi><note type="commentary" corresp="K_L00048-1"><rs type="person" ref="#pmb2121">Schnitzler</rs> bekam die Drucke des Stücks
                        am <ref target="1891-12-05" subtype="date-only" type="schnitzler-tagebuch"/>. Zwei Tage später hatte es <rs type="person" ref="#pmb11737">Hugo August
                           Hofmannsthal</rs> gelesen.</note></date>.</hi></p><p rend="center"><hi rend="pre-print">Druck von <rs type="org" ref="#pmb29612">Carl Steinhardt <c rendition="#kaufmannsund"/> Cie.</rs> (verantw. Leiter <rs type="person" ref="#pmb48802">Gu<c rendition="#langesS">s</c>tav Röttig</rs>).</hi></p></div>
      </body>
