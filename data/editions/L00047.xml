         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="1891_AS_RBH_00004"/>Hrn Dr Rich. Beer Hofma<c rendition="#gemination-n">nn</c></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb50" type="place">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb730" type="place">III. Seidlgasse 30</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1891_AS_RBH_00005"/><salute>Lieber Richard,</salute> morgen <date>So<c rendition="#gemination-n">nn</c>tag</date><space unit="chars" quantity="1"/><time>3 ½ Uhr</time> bei mir. Ja? Die <rs type="person" ref="#pmb11740 #pmb2167" subtype="implied">andern</rs> kommen<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>icher</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<lb/><signed>Arth Schn</signed></closer></div>
      </body>
