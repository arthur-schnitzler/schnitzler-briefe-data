      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="HS.NZ85.1.3175_0055"/>Herrn</hi></addrLine><addrLine><hi rend="latintype">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb168940">XVIII. Spöttelga<c rendition="#langesS">s</c>se 7</rs>.</hi></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="HS.NZ85.1.3175_0056"/><hi rend="pre-print">Gruss von der <rs type="place" ref="#pmb167610">Hühnerspielalm</rs> (<rs type="place" ref="#pmb147506">Amthorspitze</rs>) 2746 m</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="HS.NZ85.1.3175_0055"/>Wir denken Deiner in einer unwahr<c rendition="#langesS">s</c>cheinlichen Höhe
               über dem Meer u.<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>enden Dir herzliche, teils verwandt<c rendition="#langesS">s</c>chaftliche, teils
               freund<c rendition="#langesS">s</c>chaftliche Grüße. <signed>Paul Goldmann.</signed></p><p><signed><handShift scribe="#pmb2284"/>Dr. M. Hajek</signed></p><p><handShift scribe="#pmb2461"/>Herzlich<c rendition="#langesS">s</c>t <lb/><signed>Gi<c rendition="#langesS">s</c>a</signed></p><p><signed><handShift scribe="#pmb28004"/>Margot</signed></p></div>
      </body>
