      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="MS-SCHNITZLER-B-00096-B-000-00031"/>Herrn Gustav
                  Schwarzkopf</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb51">Wien I</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb207296">Tiefer Graben 23</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="MS-SCHNITZLER-B-00096-B-000-00032"/><date>26. 8.</date></dateline></opener><p><salute>lieber Gu<c rendition="#langesS">s</c>tav,</salute> der morgige Elephantenausflug unterbleibt weil <c rendition="#langesS">s</c>ich
                  <rs type="person" ref="#pmb2173">Olga</rs> eine <anchor type="commentary" xml:id="K_L04032-1"/>Kleinigkeit am Fu<c rendition="#langesS">s</c>s operiren<note type="commentary" corresp="K_L04032-1"><ref type="schnitzler-tagebuch" target="1906-08-27" subtype="Cf"/>.</note> läßt und ein paar Tage zu Haus bleiben mu<c rendition="#langesS">s</c>s.</p><closer>Herzlich<c rendition="#langesS">s</c>t u auf<lb/> bald<lb/> Ihr<lb/><signed>A.</signed></closer></div>
      </body>
