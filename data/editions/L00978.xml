   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00322"/>D<hi rend="superscript">r</hi>
                  Arthur Schnitzler</addrLine><addrLine><rs ref="#pmb146" type="place">Frankfurt a. Main</rs></addrLine><addrLine>Poste restante</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00323"/><hi rend="pre-print">Künstler-Postkarte.</hi></p><p rend="center"><hi rend="pre-print"><rs type="person" ref="#pmb44674">E. Klingebeil</rs>: <rs type="work" ref="#pmb44677">Zweierlei Pegasus</rs>.</hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00323"/><rs ref="#pmb946" type="place">Vahrn</rs><space unit="chars" quantity="1"/><date when="1899-09-19">19/IX 1899</date></dateline></opener><p><anchor type="commentary" xml:id="K_L00978-1"/><rs ref="#pmb34875" type="person">Adolf Pichler</rs><note type="commentary" corresp="K_L00978-1">Die Gegenüberstellung der beiden
                  Schriftsteller <rs type="person" ref="#pmb2121">Schnitzler</rs> und <rs ref="#pmb34875" type="person">Adolf Pichler</rs> möchte nicht nur durch die
                  Zuordnung zu den zwei auf der Karte dargestellten Poeten – der eine reitet mit
                  einer Lyra auf einem Pegasus zum Himmel, der andere mit einem Leierkasten und
                  einer Tänzerin auf einem Schwein durch den Dreck – witzig sein, sondern zieht den
                  Humor auch aus dem Altersunterschied: <rs ref="#pmb34875" type="person">Pichler</rs> wurde am <date>4. 9. 1899</date> achtzig.</note><space unit="chars" quantity="5"/> Arthur S.</p><p>Dies wünschen Ihnen</p><closer><signed>Richard</signed><lb/><signed><handShift scribe="#pmb11740"/>Hugo</signed></closer></div>
      </body>
