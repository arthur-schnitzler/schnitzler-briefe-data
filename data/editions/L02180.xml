         <div type="address"><address><addrLine><pb facs="1914_AS_RBH_1_00005"/>Herrn u Frau <hi rend="latintype">Dr. Rich.</hi></addrLine><addrLine><hi rend="latintype">Beer</hi><subst><del rend="overwritten">h</del><add place="inline"><hi rend="latintype">H</hi></add></subst><hi rend="latintype">ofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb68">Wien XVIII</rs></addrLine><addrLine><rs ref="#pmb235251" type="place"><hi rend="latintype">Hasenauerstr. 59</hi></rs>.</addrLine><addrLine><rs type="place" ref="#pmb41240"><hi rend="latintype">Austria</hi></rs></addrLine></address></div>
