      <body>
         <div type="address"><address><addrLine><pb facs="Wienbibliothek_AS_FS_2823118"/>Herrn <hi rend="latintype">Felix
                     Salten</hi></addrLine><addrLine><rs type="place" ref="#pmb169">Wien Pötzleinsdorf</rs></addrLine><addrLine><rs type="place" ref="#pmb92548">Starkfriedga<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e 12</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="Wienbibliothek_AS_FS_2823119"/><date when="1904-07-27">27. 7 904</date></dateline></opener><p><salute>lieber,</salute> für <date when="1904-07-27">morgen</date> mü<c rendition="#langesS">s</c><c rendition="#langesS">s</c>en wir leider
               ab<c rendition="#langesS">s</c>agen. Sind mit meiner <rs type="person" ref="#pmb2461" subtype="implied">Schwe<c rendition="#langesS">s</c>ter</rs> das er<c rendition="#langesS">s</c>te Mal<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>eit vielen Wochen (<hi rend="latintype"><rs type="person" ref="#pmb28004">Margot</rs><del rend="strikethrough">t</del></hi> hatte Scharlach) u das letzte Mal vor ihrer Abrei<c rendition="#langesS">s</c>e zu<c rendition="#langesS">s</c>ammen.</p><p>Auf <anchor type="commentary" xml:id="K_L02992-1"/>näch<c rendition="#langesS">s</c>te Woche<note type="commentary" corresp="K_L02992-1"><ref type="schnitzler-tagebuch" target="1904-08-04" subtype="See"/>.
               </note></p><closer>Herzlichen Gruß <lb/>Ihr <lb/><signed>A.</signed></closer><postscript><p><anchor type="textConst" xml:id="T_L02992-1"/>Die <anchor type="commentary" xml:id="K_L02992-2"/>Bilder<note type="commentary" corresp="K_L02992-2"><ref type="schnitzler-tagebuch" target="1904-07-25" subtype="See"/>.
                  </note><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind da<supplied>.</supplied><space unit="chars" quantity="1"/><rs type="person" ref="#pmb2173">Olga</rs> und andre<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind entzückt.<note type="textConst" corresp="T_L02992-1">seitlich am rechten Rand, quer zum
                     Text</note></p></postscript></div>
      </body>
