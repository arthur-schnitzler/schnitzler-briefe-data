      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00014"/><hi rend="latintype">Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><rs type="place" ref="#pmb50"><hi rend="latintype">Wien</hi></rs></addrLine><addrLine><rs ref="#pmb168934" type="place"><hi rend="latintype">IX Franckgasse 1</hi></rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00013"/><salute>lieber Arthur</salute> ich möchte Sie<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr gerne eine Stunde <hi rend="underline" n="1">ruhig</hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>prechen, haupt<c rendition="#langesS">s</c>ächlich wegen <rs type="person" ref="#pmb11737" subtype="implied">Papa</rs>. Geht es vielleicht
                  <date>Mittwoch</date><space unit="chars" quantity="1"/><time>½ 3</time>? oder<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>on<c rendition="#langesS">s</c>t?</p><closer>Herzlich Ihr<signed>Hugo.</signed></closer></div>
      </body>
