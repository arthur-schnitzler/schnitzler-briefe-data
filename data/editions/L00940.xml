   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00299"/>Herrn</addrLine><addrLine>D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><rs ref="#pmb168934" type="place">IX Frankgasse 1</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00298"/><salute>Lieber Arthur,</salute> unsere Briefe haben sich gekreuzt. Schreiben Sie mir
               genau od telegrafiren Sie mit welchem Zug Sie ko<c rendition="#gemination-m">mm</c>en
               (hieher) Damit ich in <rs ref="#pmb41052" type="place">Spittal</rs> sie erwarten
               kann.</p><closer>Von Herzen<lb/><signed>Richard</signed></closer><postscript><p>Ko<c rendition="#gemination-m">mm</c>en Sie <hi rend="underline" n="1">Donnerstag</hi>
                  nicht <hi n="1" rend="underline">Mittwoch</hi></p></postscript></div>
      </body>
