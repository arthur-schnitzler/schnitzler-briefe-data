      <body>
         <div type="address"><address><addrLine><pb facs="Wienbibliothek_AS_FS_2823267"/>Herrn <hi rend="latintype">Felix
                     Salten</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb52510">IX Berggasse 13</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute rend="left"><pb facs="Wienbibliothek_AS_FS_2823266"/>Lieber Salten,</salute></opener><p>morgen <date when="1892-10-09">So<c rendition="#gemination-n">nn</c>tag</date><space unit="chars" quantity="1"/><time>Nachmittag <hi rend="underline" n="2">4 Uhr</hi></time><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind <hi rend="latintype"><rs type="person" ref="#pmb10863">BHofm</rs></hi> u ich <hi rend="latintype"><rs type="place" ref="#pmb1105">Stefansplatz</rs></hi>, wollen in die <anchor type="commentary" xml:id="K_L02957-1"/><rs type="org" ref="#pmb45127">Aus<c rendition="#langesS">s</c>tellung</rs><note type="commentary" corresp="K_L02957-1">die <rs type="org" ref="#pmb45127">Internationale Ausstellung für Musik und Theaterwesen</rs> im
                     <rs type="place" ref="#pmb50">Wien</rs>er <rs type="place" ref="#pmb8">Prater</rs></note>. – Ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chrieb auch an <hi rend="latintype"><rs type="person" ref="#pmb26121">Torresani</rs></hi>. Ko<c rendition="#gemination-m">mm</c>en Sie doch auch!</p><closer>Herzlich <signed>ArthSchn</signed></closer></div>
      </body>
