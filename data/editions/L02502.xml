      <body>
         <div type="writingSession" n="1"><p><pb facs=""/>Herr und Frau von Hofmannsthal geben Nachricht von der
               Vermälung ihrer Tochter <rs type="person" ref="#pmb3220">Christiane</rs>
               mit D<hi rend="superscript">r</hi><space unit="chars" quantity="1"/><rs type="person" ref="#pmb13183">Heinrich
                  Zimmer</rs>, Professor der indischen Philologie an der <rs type="org" ref="#pmb51306">Universität Heidelberg</rs>.</p><postscript><dateline><rs type="place" ref="#pmb173">Rodaun</rs>, im <anchor type="commentary" xml:id="K_L02502-1"/><date>Juni 1928</date><note type="commentary" corresp="K_L02502-1">Die Hochzeit fand am
                        <date>14. 6. 1928</date> statt.</note>.</dateline></postscript></div>
      </body>
