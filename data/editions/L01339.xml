      <body>
         <div type="address"><address><addrLine><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00222"/><hi rend="latintype">Herrn Hermann Bahr</hi></addrLine><addrLine><rs ref="#pmb165" type="place">Wien-Ob. St. Veit</rs></addrLine><addrLine><rs ref="#pmb220" type="place">Veitli<c rendition="#langesS">s</c><c rendition="#langesS">s</c>enga<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e 15</rs></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="Arthur-Schnitzler_an_Hermann-Bahr_00223"/><salute>lieber Hermann,</salute>du ha<c rendition="#langesS">s</c>t dich für den <anchor type="commentary" xml:id="K_L01339-1"/><rs ref="#pmb29975" type="work"><hi rend="underline" n="1">Goethe Zelter</hi> Briefwech<c rendition="#langesS">s</c>el</rs><note type="commentary" corresp="K_L01339-1">nicht unter den aus <rs ref="#pmb10815" type="person">Bahrs</rs> Besitz überlieferten Büchern</note> intere<c rendition="#langesS">s</c><c rendition="#langesS">s</c>irt. Im
                  <hi rend="latintype">Catalog XXXIV</hi><space unit="chars" quantity="1"/><rs ref="#pmb29255" type="org"><c rendition="#langesS">s</c>üddeut<c rendition="#langesS">s</c>ches Antiquariat</rs>, <rs ref="#pmb448" type="place"><hi rend="underline" n="1">München</hi> Gallerie<c rendition="#langesS">s</c>traße 20</rs>, unter Nr 699 i<c rendition="#langesS">s</c>t
               ein Exemplar, 6 Bände um 40 Mark angekündigt. Herzlich<c rendition="#langesS">s</c>t dein<lb/><signed>Arth Sch</signed></p></div>
      </body>
