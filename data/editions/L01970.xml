      <body>
         <div type="address"><address><addrLine><pb facs="1910_AS_RBH_2_00013"/><hi rend="latintype">Herrn Dr. Richard Beer Hofmann</hi></addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="1910_AS_RBH_2_00014"/>lieber Richard,</salute></opener><p>heute Abend (<time>½ 8</time>)<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind <rs type="person" ref="#pmb12698" subtype="implied">Bruder</rs> u. <rs type="person" ref="#pmb24423" subtype="implied">Schwägerin</rs> (<c rendition="#langesS">s</c>on<c rendition="#langesS">s</c>t niemand) bei uns, mit denen Sie <add place="above">(=<rs type="person" ref="#pmb10860" subtype="implied">Ihr</rs>)</add><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chon immer<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>o gern bei<c rendition="#langesS">s</c>a<c rendition="#gemination-m">mm</c>en<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein
               wollten;<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ie, und wir, (und hoffentlich auch Sie) würden <subst><del rend="overwritten">uns</del><add place="inline"><c rendition="#langesS">s</c>ich</add></subst>, uns <subst><del rend="overwritten">,</del><add place="inline">(</add></subst>und<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ich)<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ehr freuen, we<c rendition="#gemination-n">nn</c> Sie <add place="above">(=<rs type="person" ref="#pmb10860" subtype="implied">Ihr</rs>)</add> kämen.</p><closer>Herzlich<c rendition="#langesS">s</c>t<lb/>Ihr<lb/><signed>Arthur</signed></closer><postscript><dateline><date when="1910-10-23">23/X 910</date>.</dateline></postscript></div>
      </body>
