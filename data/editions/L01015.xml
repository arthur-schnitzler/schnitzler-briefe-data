      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00332"/>D<hi rend="superscript">r</hi>
                  Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs ref="#pmb168934" type="place">IX Frankgasse 1</rs></addrLine><addrLine><rs ref="#pmb41240" type="place">Austria</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00333"/><hi rend="pre-print"><rs type="person" ref="#pmb49237">Manuel Wielandt</rs>.</hi></p><p rend="center"><hi rend="pre-print"><rs type="place" ref="#pmb45279"><hi rend="capitals">San Remo</hi></rs></hi></p></div>
         <div type="writingSession" n="1"><opener><dateline><seg rend="left"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00333"/><hi rend="underline" n="1"><rs ref="#pmb40055" type="place">Hôtel de Rome</rs></hi></seg><seg rend="right"><date when="1900-11-18">18/II 1900</date>.</seg></dateline></opener><p><salute>Lieber Arthur,</salute> ko<c rendition="#gemination-m">mm</c>en Sie mit <rs ref="#pmb21236" type="person">Mayer</rs> doch her, wir gehen dann nach <rs ref="#pmb263" type="place">Florenz</rs>. – Ich weiß übrigens: weil Sie nichts in
                  <rs ref="#pmb50" type="place">Wien</rs> hält, können Sie nicht fort. Herzlichst
               Ihr</p><closer><signed>Richard</signed></closer></div>
      </body>
