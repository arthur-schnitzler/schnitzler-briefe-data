         <div type="address"><address><addrLine><pb facs="1910_OS_RBH_1_00010"/>Herrn u. <rs ref="#pmb10860" type="person" subtype="implied">Frau</rs></addrLine><addrLine>D<hi rend="superscript">r</hi> Richard Beer-Hofmann</addrLine><addrLine><rs type="place" ref="#pmb68">Wien XVIII</rs></addrLine><addrLine><rs ref="#pmb235251" type="place">Hasenauerstrasse 59</rs>.</addrLine></address></div>
