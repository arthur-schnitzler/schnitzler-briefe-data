      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00308"/>D<hi rend="superscript">r</hi>
                  Arthur Schnitzler</addrLine><addrLine><rs ref="#pmb213" type="place">Ischl</rs></addrLine><addrLine><rs ref="#pmb414" type="place">Pension Leopold</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00309"/><hi rend="pre-print"><rs ref="#pmb41430" type="place">Sachsenburg</rs></hi></p></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="MS-SCHNITZLER-B-0008-B-00001-000-00309"/><date when="1899-08-28">28/VIII 99</date></dateline></opener><p><salute>Lieber Arthur!</salute> Wir – <rs ref="#pmb10860" type="person">Paula</rs>,
                  <rs ref="#pmb2668" type="person">Mirjam</rs> u ich haben einen Ausflug <rs type="place" ref="#pmb41430" subtype="implied">hieher</rs> gemacht. »<rs ref="#pmb30233" type="work">Die unseelige Mitgift</rs>« ist seit 3 Tagen begonnen.
               Herzlichst Ihr <signed>R.</signed></p></div>
      </body>
