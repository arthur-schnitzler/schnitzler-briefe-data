         <div type="address"><address><addrLine><pb facs="https://www.theatermuseum.at/de/object/eb5249560c/"/>Herrn Hermann
                  Bahr</addrLine><addrLine><rs ref="#pmb165" type="place">Wien Ob St Veit</rs></addrLine><addrLine><rs ref="#pmb220" type="place">Veitli<c rendition="#langesS">s</c><c rendition="#langesS">s</c>enga<c rendition="#langesS">s</c><c rendition="#langesS">s</c>e</rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="https://www.theatermuseum.at/de/object/eb5249560c/"/><hi rend="pre-print"><rs ref="#pmb64" type="place">Hietzing</rs>, den <c rendition="#dots" n="3"/>
                  19<c rendition="#dots" n="3"/></hi></p><p rend="center"><hi rend="pre-print"><rs ref="#pmb449" type="place">Auhofstrasse 1</rs>.</hi></p><p><hi rend="pre-print">Schöner Gruss vom reizenden Etablissement ›<rs ref="#pmb304" type="place">Ottakringerbräu</rs>‹ ›zum schwarzen Hahn‹, wo es so gemüthlich
                  ist.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="https://www.theatermuseum.at/de/object/eb5249560c/"/><rs ref="#pmb29983" type="work">Dem Meister</rs>. – 10<c rendition="#prozent"/>!</p><p><date>14. 12. 03</date></p><p><anchor type="commentary" xml:id="K_L01351-1"/><rs ref="#pmb29909" type="work">Unter sich</rs><note type="commentary" corresp="K_L01351-1">Die <rs ref="#pmb29779" type="org">11
                     Scharfrichter</rs> hatten <rs ref="#pmb10815" type="person">Bahrs</rs><space unit="chars" quantity="1"/>Schauspiel <rs ref="#pmb29909" type="work">Unter
                     sich</rs> am <date>9. 12. 1903</date> in <rs ref="#pmb50" type="place">Wien</rs> gegeben.</note>:</p><closer><signed>Arthur</signed></closer><postscript><p><signed><handShift scribe="#pmb2173"/>Olga S.</signed><lb/><signed><handShift scribe="#pmb11740"/>Hugo (ich bin nicht der <rs type="work" ref="#pmb29909" subtype="implied"><anchor type="commentary" xml:id="K_L01351-2"/>Onkel<note type="commentary" corresp="K_L01351-2">Figur aus <rs ref="#pmb29909" type="work">Unter sich</rs>.</note></rs>)</signed><lb/><signed><handShift scribe="#pmb2292"/>Gerty</signed><lb/><signed><handShift scribe="#pmb10863"/>Richard</signed></p></postscript></div>
      </body>
