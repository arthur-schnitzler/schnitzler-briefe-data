         <div type="address"><address><addrLine><pb facs="1897_AS_RBH_2_00057"/>Herrn Doctor</addrLine><addrLine>Richard Beer-Hofmann</addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb585" type="place">VIII. Hotel Ha<c rendition="#gemination-m">mm</c>erand</rs> (<rs ref="#pmb42773" type="place">Schlösselgasse</rs>)</hi></addrLine></address></div>
