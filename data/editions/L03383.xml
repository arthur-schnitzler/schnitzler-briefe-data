      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="HS.NZ85.1.3173_0047"/>Herrn</hi></addrLine><addrLine><hi rend="latintype">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb168934">IX. Frankga<c rendition="#langesS">s</c>se 1</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="left"><pb facs="HS.NZ85.1.3173_0048"/><date when="1903-08-11">Dien<c rendition="#langesS">s</c>tag</date><space unit="chars" quantity="1"/><time>Abend</time>.</dateline><salute rend="left">Mein lieber Freund,</salute></opener><p>Ich <anchor type="commentary" xml:id="K_L03383-1"/>fahre<note type="commentary" corresp="K_L03383-1"><ref type="schnitzler-briefe" target="L03375" subtype="See"/>.
               </note><space unit="chars" quantity="1"/><date when="1903-08-11">heut</date><space unit="chars" quantity="1"/><time>Abend</time>, habe <date when="1903-08-12">morgen</date><space unit="chars" quantity="1"/><time>Nachmittag</time> in <rs type="place" ref="#pmb40264">Franzensfe<c rendition="#langesS">s</c>te</rs><space unit="chars" quantity="1"/><rs type="person" subtype="implied" ref="#pmb23674">Rendezvous</rs>, dürfte <date when="1903-08-12">morgen</date><space unit="chars" quantity="1"/><time>Abend</time> in <hi rend="latintype"><rs type="place" ref="#pmb101487">Klausen</rs></hi> (<hi rend="latintype"><rs type="place" ref="#pmb147017">Hotel Lamm</rs></hi>)<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ein. <date when="1903-08-13">Donner<c rendition="#langesS">s</c>tag</date><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ende ich Dir Nachricht nach
                  <hi rend="latintype"><rs type="place" ref="#pmb40260">Bozen</rs></hi>. Du kannft mir bis <date when="1903-08-13">Donner<c rendition="#langesS">s</c>tag</date><space unit="chars" quantity="1"/><time>früh</time> Nachricht nach <hi rend="latintype"><rs type="place" ref="#pmb101487">Klausen</rs></hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>enden, wenn Du will<c rendition="#langesS">s</c>t.</p><closer>Leb’ wohl! Glückliche Rei<c rendition="#langesS">s</c>e! Tau<c rendition="#langesS">s</c>end Dank! Grüße! <lb/>Dein <signed>Paul
                  Goldm</signed></closer></div>
      </body>
