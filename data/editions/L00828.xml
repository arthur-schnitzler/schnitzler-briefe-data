      <body>
         <div type="address"><address><addrLine><pb facs="1898_AS_RBH_3_00014"/>Herrn <hi rend="latintype">Dr. Richard
                     Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb34860" type="place">Steindorf</rs></hi></addrLine><addrLine><hi rend="latintype">am <rs ref="#pmb40374" type="place">Ossiacher</rs></hi><c rendition="#langesS">s</c>ee</addrLine><addrLine><rs ref="#pmb651" type="place"><hi rend="latintype">Kärnthen</hi></rs>.</addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1898_AS_RBH_3_00015"/><hi rend="pre-print"><hi rend="capitals">Gruss vom <rs ref="#pmb42905" type="place">Café am See</rs></hi></hi></p><p rend="center"><hi rend="pre-print"><rs ref="#pmb39752" type="place">Tegernsee</rs>.</hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1898_AS_RBH_3_00015"/><salute>Lieber Richard,</salute><space unit="chars" quantity="1"/><rs type="place" ref="#pmb39752" subtype="implied">hier</rs> bleib ich mind<c rendition="#langesS">s</c>ts
               8 Tage. Die Gegend i<c rendition="#langesS">s</c>t in Wirklichkeit be<c rendition="#langesS">s</c><c rendition="#langesS">s</c>er gemalt! Ich wohne <rs ref="#pmb34048" type="place">Hotel Po<c rendition="#langesS">s</c>t</rs>.</p><closer>Herzliche Grüße Ihr <signed>Arthur</signed></closer></div>
      </body>
