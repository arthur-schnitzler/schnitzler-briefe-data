         <div type="address"><address><addrLine><pb facs="0019_FL81799717"/>Herrn Dr Phil. Stefan Zweig</addrLine><addrLine><rs type="place" ref="#pmb51">Wien I</rs></addrLine><addrLine><rs type="place" ref="#pmb296105">Rathhaustraße 17</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><opener><seg rend="right"><pb facs="0018_FL81799560"/><hi rend="latintype"><rs type="place" ref="#pmb133">XVIII
                        Spoettelgasse 7</rs></hi></seg><dateline rend="right"><rs type="place" ref="#pmb50">Wien</rs>,
                        <date>17. 10 90<unclear>4</unclear></date></dateline><salute>verehrte<c rendition="#langesS">s</c>ter Herr Doktor,</salute></opener><p><c rendition="#langesS">s</c>chön<c rendition="#langesS">s</c>ten Dank für die liebenswürdg Über<c rendition="#langesS">s</c>endg Ihres <rs type="work" ref="#pmb33716" subtype="implied">Novellenbuches</rs>, auf de<c rendition="#langesS">s</c><c rendition="#langesS">s</c>en Lecture ich mich
                  aufricht<unclear>g</unclear> freue.</p><closer>Ihr Sie hoch<c rendition="#langesS">s</c>chätzender<lb/><signed>Arthur Schnitzler.</signed></closer></div>
      </body>
