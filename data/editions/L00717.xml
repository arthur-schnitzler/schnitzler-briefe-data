      <body>
         <div type="address"><address><addrLine><pb facs="1897_AS_RBH_2_00062"/>Herrn Dr. <hi rend="latintype">Richard
                     Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb30" type="place"><hi rend="latintype">Salzburg</hi></rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb230" type="place">Hotel Oesterreichischer Hof</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="right"><pb facs="1897_AS_RBH_2_00064"/><date>Din<c rendition="#langesS">s</c>tag</date></dateline></opener><p><salute>Lieber Richard.</salute><space unit="chars" quantity="1"/><date>Do<c rendition="#gemination-n">nn</c>er<c rendition="#langesS">s</c>tag</date><space unit="chars" quantity="1"/><date>Abend</date> oder <date>Freitg</date><space unit="chars" quantity="1"/><date>früh</date> bin ich in <rs ref="#pmb213" type="place">I<c rendition="#langesS">s</c>chl</rs>. Das Zi<c rendition="#gemination-m">mm</c>er für <rs ref="#pmb11485" type="person">Paul</rs> bei
                  <rs ref="#pmb22474" type="person">Petter</rs> be<c rendition="#langesS">s</c>tellt. Trifft Sie die<c rendition="#langesS">s</c>er Brief
               überhaupt noch in <rs ref="#pmb30" type="place">Salzburg</rs>? –</p><p>Grüßen Sie <rs ref="#pmb11485" type="person">Paul</rs> herzlich; auch<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ich<space unit="chars" quantity="1"/><c rendition="#langesS">s</c>elb<c rendition="#langesS">s</c>t.</p><closer>Ihr <signed>Arthur</signed></closer></div>
      </body>
