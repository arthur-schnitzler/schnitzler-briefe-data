         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00089-B-00002-000-00028-V"/>Herrn</addrLine><addrLine>D<hi rend="superscript">r</hi> Arthur Schnitzler</addrLine><addrLine><rs type="place" ref="#pmb50">Wien</rs></addrLine><addrLine><rs type="place" ref="#pmb168815">XVIII. Sternwartestraße 71</rs></addrLine></address></div>
