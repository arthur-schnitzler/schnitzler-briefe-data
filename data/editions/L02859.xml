   <text>
      <body>
         <div type="address"><address><addrLine><hi rend="latintype"><pb facs="HS.NZ85.1.3168_0059"/><rs type="place" ref="#pmb41240">Austria</rs>.</hi></addrLine><addrLine><hi rend="latintype">Herrn</hi></addrLine><addrLine><hi rend="latintype">Dr. Arthur Schnitzler</hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb50">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb168934">IX. Frankga<c rendition="#langesS">s</c>se 1</rs>.</hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><dateline rend="left"><pb facs="HS.NZ85.1.3168_0058"/><hi rend="latintype"><rs type="place" ref="#pmb118682">Tientsin</rs></hi>, <date when="1898-09-28">28. September</date>.</dateline></opener><p><salute>Vielen Dank, lieber Freund,</salute> für Deine Karte aus
                  <anchor type="commentary" xml:id="K_L02859-1"/><rs type="place" ref="#pmb562">Genf</rs><note type="commentary" corresp="K_L02859-1"><rs type="person" ref="#pmb2121">Schnitzler</rs> hielt sich vom <ref type="schnitzler-tagebuch" target="1898-08-16" subtype="date-only"/> bis zum <ref type="schnitzler-tagebuch" target="1898-08-18" subtype="date-only"/> in <rs type="place" ref="#pmb562">Genf</rs> auf und traf dort an den ersten beiden
                  Tagen seine Schwester <rs type="person" ref="#pmb2461">Gisela</rs> und seinen
                  Schwager <rs type="person" ref="#pmb2284">Markus Hajek</rs> sowie <rs type="person" ref="#pmb11740">Hugo von Hofmannsthal</rs>.</note>! Bitte, auch
               Deiner Frau <rs type="person" subtype="implied" ref="#pmb2461">Schwe<c rendition="#langesS">s</c>ter</rs>, Deinem
               Herrn <rs type="person" subtype="implied" ref="#pmb2284">Schwager</rs> und Herrn von
                  <hi rend="latintype"><rs type="person" ref="#pmb11740">Hoffmansthal</rs></hi> für die freundlichen Grüße zu <del rend="strikethrough">danken!</del> danken!</p><closer>Dein<lb/><signed>P. G.</signed></closer></div>
      </body>
