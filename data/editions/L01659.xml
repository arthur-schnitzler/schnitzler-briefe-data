      <body>
         <div type="address"><address><addrLine><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00267"/><hi rend="latintype">Herrn D<hi rend="superscript">r</hi> Arthur Schnitzler</hi></addrLine><addrLine><rs type="place" ref="#pmb50"><hi rend="latintype">Wien</hi></rs></addrLine><addrLine><rs ref="#pmb168940" type="place"><hi rend="latintype">XVII Spöttelgasse 7</hi></rs></addrLine><addrLine>näch<c rendition="#langesS">s</c>t <rs type="place" ref="#pmb43882">Türkenschanzstrasse</rs></addrLine><addrLine><hi rend="latintype">pneumatisch</hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="MS-SCHNITZLER-B-00043-B-00002-000-00268"/>Wir gehen heute abend zu den <rs type="person" ref="#pmb10860 #pmb10863">† † † Bären</rs> und möchten am Weg bei
               Euch hinein<c rendition="#langesS">s</c>chauen d. h. circa <time>5<hi rend="superscript">h</hi> Uhr</time>. Falls
               lä<c rendition="#langesS">s</c>tig bitte ab<c rendition="#langesS">s</c>agen telephoni<c rendition="#langesS">s</c>ch N. 229.</p><closer><signed>Hugo.</signed></closer></div>
      </body>
