   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1895_AS_RBH_3_00024"/>Herrn</addrLine><addrLine><hi rend="latintype">Dr. Rich Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs>.</addrLine><addrLine><hi rend="latintype"><rs ref="#pmb190427" type="place">I. Wollzeile 15</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><opener><salute><pb facs="1895_AS_RBH_3_00025"/>Lieber Richard</salute></opener><p><hi rend="latintype">I. Gallerie</hi>, rechts</p><p><anchor type="commentary" xml:id="K_L00502-1"/>Loge 4<note type="commentary" corresp="K_L00502-1"><rs type="person" ref="#pmb2121">Schnitzler</rs> besuchte die <rs type="event" ref="#pmb42426">zweite Aufführung</rs> von <rs ref="#pmb29917" type="work">Liebelei</rs>, die <rs type="event" ref="#pmb35203" subtype="implied">Uraufführung</rs> dürfte er hinter der Bühne erlebt
                  haben.</note>.</p><p>Bitte ko<c rendition="#gemination-m">mm</c>en Sie</p><closer>Herzlich Ihr <signed>Arthur</signed></closer></div>
      </body>
