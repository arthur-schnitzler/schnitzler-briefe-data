   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1897_AS_RBH_1_00008"/>Herrn Dr <hi rend="latintype">Rich.
                     Beer-Hofmann</hi></addrLine><addrLine><rs ref="#pmb50" type="place">Wien</rs></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb190427" type="place">I. Wollzeile 15.</rs></hi></addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1897_AS_RBH_1_00010"/><salute>lieber Richard,</salute> bitte ko<c rendition="#gemination-m">mm</c>en Sie <anchor type="commentary" xml:id="K_L00652-1"/><rs type="event" subtype="implied" ref="#pmb142793">morgen</rs><note type="commentary" corresp="K_L00652-1"><ref type="schnitzler-kultur" target="pmb142793" subtype="Cf"/>.</note><add place="above">(Mittwoch)</add> nach dem Nachtmahl zu mir. Ihr Rath erwün<c rendition="#langesS">s</c>cht.
               Ihre Ge<c rendition="#langesS">s</c>ellschaft <pb facs="1897_AS_RBH_1_00011"/>noch mehr. <rs ref="#pmb11701" type="person">Georg Hir<c rendition="#langesS">s</c>chf.</rs> u <rs ref="#pmb10815" type="person">Bahr</rs><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>ind da.</p><closer>Herzlich Ihr <signed>Arthur</signed></closer></div>
      </body>
