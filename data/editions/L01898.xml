   <text>
      <body>
         <div type="address"><address><addrLine><pb facs="1909_OS_RBH_1_00007"/>Herrn u. Frau</addrLine><addrLine>D<hi rend="superscript">r</hi> Richard Beer-Hofmann</addrLine><addrLine><rs ref="#pmb235251" type="place">Hasenauerstrasse 59</rs>.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1909_OS_RBH_1_00008"/><salute>Liebe Beer-Hofmanns,</salute><space unit="chars" quantity="1"/><anchor type="commentary" xml:id="K_L01898-1"/>morgen<note type="commentary" corresp="K_L01898-1"><ref target="1909-12-13" subtype="See" type="schnitzler-tagebuch"/>.
               </note><space unit="chars" quantity="1"/><time>Abend</time> kommen <rs type="person" ref="#pmb2496">Kaufmann</rs>, <rs type="person" ref="#pmb26392">Leo</rs> und wahrscheinlich auch <rs type="person" ref="#pmb2167 #pmb23918">Saltens</rs> zu uns, wir würden uns sehr freuen und das
               Gefühl von 2 aufgesetzten Kronen haben, wenn Ihr auch kämet.</p><closer>Herzliche Grüsse!<lb/><signed>Olga.</signed></closer><postscript><p><anchor type="commentary" xml:id="K_L01898-2"/>Sonntag<note type="commentary" corresp="K_L01898-2">Die Datierung folgt dem
                     Tagebucheintrag vom <ref target="1909-12-13" subtype="date-only" type="schnitzler-tagebuch"/></note>.<space unit="chars" quantity="3"/>Bitte früh kommen!</p></postscript></div>
      </body>
