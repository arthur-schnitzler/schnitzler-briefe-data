      <body>
         <div type="address"><address><addrLine><pb facs="1914_AS_RBH_1_00003"/>Hrn <hi rend="latintype">Dr. Richard Beer
                     Hofmann</hi></addrLine><addrLine>und Frau.</addrLine><addrLine><hi rend="latintype"><rs type="place" ref="#pmb68">Wien XVIII</rs></hi></addrLine><addrLine><rs ref="#pmb235251" type="place"><hi rend="latintype">Hasenauerstr 59</hi></rs></addrLine></address></div>
         <div type="image"><p rend="center"><pb facs="1914_AS_RBH_1_00002"/><hi rend="pre-print"><rs type="place" ref="#pmb46241">Genova – Piazza De Ferrari</rs></hi></p></div>
         <div type="writingSession" n="1"><p><pb facs="1914_AS_RBH_1_00003"/>Herzliche Grüße!</p><closer>Ihr <signed>Arthur</signed></closer></div>
         <div type="writingSession" n="2"><p><handShift scribe="#pmb2173"/>Haben in <rs ref="#pmb263" type="place">Florenz</rs> in
               einem <anchor type="commentary" xml:id="K_L02178-1"/>Varieté<note type="commentary" corresp="K_L02178-1"><ref target="1914-05-09" type="schnitzler-tagebuch" subtype="Cf"/>.
               </note> besonders heftig Ihrer gedacht. – was Sie nun neugierig machen möge!</p><closer>Herzlichst <signed>Olga.</signed></closer></div>
         <div type="writingSession" n="3"><p><handShift scribe="#pmb2121"/><anchor type="commentary" xml:id="K_L02178-2"/>Morgen<note type="commentary" corresp="K_L02178-2">Das erlaubt, die Karte am Tag
                  vor dem Poststempel zu datieren, da die Abfahrt am <ref target="1914-05-13" type="schnitzler-tagebuch" subtype="date-only"/> stattfand.</note> ab nach <rs ref="#pmb43991" type="place">Algier</rs></p></div>
      </body>
