      <body>
         <div type="address"><address><addrLine><pb facs="1891_AS_RBH_00007"/>Hrn <hi rend="latintype">Dr. Rich. Beer-Hofmann</hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb50" type="place">Wien</rs></hi></addrLine><addrLine><hi rend="latintype"><rs ref="#pmb730" type="place">III. Seidlgasse 30</rs></hi>.</addrLine></address></div>
         <div type="writingSession" n="1"><p><pb facs="1891_AS_RBH_00008"/><salute>Lieber Richard!</salute><space unit="chars" quantity="1"/><anchor type="commentary" xml:id="K_L00045-1"/><date>So<c rendition="#gemination-n">nn</c>tag</date><note type="commentary" corresp="K_L00045-1">Am Sonntag, den <ref type="schnitzler-tagebuch" subtype="date-only" target="1891-11-22"/> trafen
                  sich <rs ref="#pmb11740" type="person">Hofmannsthal</rs>, <rs ref="#pmb10863" type="person">Beer-Hofmann</rs> und <rs ref="#pmb2167" type="person">Salten</rs> bei <rs type="person" ref="#pmb2121">Schnitzler</rs>.</note><space unit="chars" quantity="1"/><time>Nachmittag 4 Uhr</time> bin ich zu Hau<c rendition="#langesS">s</c>e. <hi rend="latintype"><rs ref="#pmb11740" type="person">Loris</rs></hi> ko<c rendition="#gemination-m">mm</c>t auch. An <hi rend="latintype"><rs ref="#pmb2167" type="person">Salten</rs></hi><space unit="chars" quantity="1"/><c rendition="#langesS">s</c>chreibe ich.</p><closer>Herzlich<c rendition="#langesS">s</c>t Ihr<signed>Arth Schn</signed></closer></div>
      </body>
